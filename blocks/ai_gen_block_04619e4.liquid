{% doc %}
  @prompt
    ⚡ 5. BLOQUE DE CONVERSIÓN
    
    Agrega esto:
    
    📦 Envíos rápidos a toda Colombia
    📚 Curaduría especializada
    🔒 Compra segura
    📖 Más de 35 años de experiencia
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-conversion-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-conversion-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-conversion-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.alignment }};
    text-align: {{ block.settings.alignment }};
    gap: {{ block.settings.item_gap }}px;
  }

  .ai-conversion-icon-{{ ai_gen_id }} {
    font-size: {{ block.settings.icon_size }}px;
    line-height: 1;
  }

  .ai-conversion-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0;
    font-weight: {{ block.settings.text_weight }};
  }

  @media screen and (max-width: 749px) {
    .ai-conversion-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<conversion-block-{{ ai_gen_id }}
  class="ai-conversion-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-conversion-grid-{{ ai_gen_id }}">
    {% if block.settings.feature_1_enabled %}
      <div class="ai-conversion-item-{{ ai_gen_id }}">
        <div class="ai-conversion-icon-{{ ai_gen_id }}">
          {{ block.settings.feature_1_icon }}
        </div>
        <p class="ai-conversion-text-{{ ai_gen_id }}">
          {{ block.settings.feature_1_text }}
        </p>
      </div>
    {% endif %}

    {% if block.settings.feature_2_enabled %}
      <div class="ai-conversion-item-{{ ai_gen_id }}">
        <div class="ai-conversion-icon-{{ ai_gen_id }}">
          {{ block.settings.feature_2_icon }}
        </div>
        <p class="ai-conversion-text-{{ ai_gen_id }}">
          {{ block.settings.feature_2_text }}
        </p>
      </div>
    {% endif %}

    {% if block.settings.feature_3_enabled %}
      <div class="ai-conversion-item-{{ ai_gen_id }}">
        <div class="ai-conversion-icon-{{ ai_gen_id }}">
          {{ block.settings.feature_3_icon }}
        </div>
        <p class="ai-conversion-text-{{ ai_gen_id }}">
          {{ block.settings.feature_3_text }}
        </p>
      </div>
    {% endif %}

    {% if block.settings.feature_4_enabled %}
      <div class="ai-conversion-item-{{ ai_gen_id }}">
        <div class="ai-conversion-icon-{{ ai_gen_id }}">
          {{ block.settings.feature_4_icon }}
        </div>
        <p class="ai-conversion-text-{{ ai_gen_id }}">
          {{ block.settings.feature_4_text }}
        </p>
      </div>
    {% endif %}
  </div>
</conversion-block-{{ ai_gen_id }}>

