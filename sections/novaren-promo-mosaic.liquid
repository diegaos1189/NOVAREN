<section class="nvpromo section-{{ section.id }}">
  <div class="nvpromo-shell">
    {% if section.settings.heading != blank or section.settings.text != blank %}
      <header class="nvpromo-head">
        {% if section.settings.eyebrow != blank %}<p>{{ section.settings.eyebrow }}</p>{% endif %}
        {% if section.settings.heading != blank %}<h2>{{ section.settings.heading }}</h2>{% endif %}
        {% if section.settings.text != blank %}<div>{{ section.settings.text }}</div>{% endif %}
      </header>
    {% endif %}

    <div class="nvpromo-grid">
      {% for block in section.blocks %}
        <article class="nvpromo-card {% if forloop.first %}is-large{% endif %}" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1400
              | image_tag:
                widths: '480, 720, 960, 1400',
                sizes: '(min-width: 990px) 50vw, 100vw',
                loading: 'lazy',
                class: 'nvpromo-card__image',
                alt: block.settings.image_alt | default: block.settings.heading
            }}
          {% endif %}
          <div class="nvpromo-card__shade"></div>
          <div class="nvpromo-card__content">
            {% if block.settings.badge != blank %}<span>{{ block.settings.badge }}</span>{% endif %}
            <h3>{{ block.settings.heading }}</h3>
            {% if block.settings.text != blank %}<p>{{ block.settings.text }}</p>{% endif %}
            {% if block.settings.button_label != blank %}
              <a href="{{ block.settings.button_link }}">{{ block.settings.button_label }}</a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .section-{{ section.id }} {
    --ink: #10231c;
    --muted: #66746d;
    --green: {{ section.settings.accent_color }};
    background: {{ section.settings.background }};
    color: var(--ink);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  .section-{{ section.id }} .nvpromo-shell {
    width: calc(100% - 32px);
    max-width: 1180px;
    margin-inline: auto;
  }

  .section-{{ section.id }} .nvpromo-head {
    max-width: 780px;
    margin-bottom: 28px;
  }

  .section-{{ section.id }} .nvpromo-head p {
    margin: 0 0 10px;
    color: var(--green);
    font-size: 12px;
    font-weight: 850;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .section-{{ section.id }} .nvpromo-head h2 {
    margin: 0;
    color: var(--ink);
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.05;
  }

  .section-{{ section.id }} .nvpromo-head div {
    margin-top: 12px;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.62;
  }

  .section-{{ section.id }} .nvpromo-grid {
    display: grid;
    grid-template-columns: 1.25fr .75fr;
    grid-auto-rows: minmax(220px, auto);
    gap: 18px;
  }

  .section-{{ section.id }} .nvpromo-card {
    position: relative;
    min-height: 280px;
    border-radius: 8px;
    overflow: hidden;
    isolation: isolate;
    background: #10231c;
    box-shadow: 0 22px 70px rgba(16,35,28,.14);
  }

  .section-{{ section.id }} .nvpromo-card.is-large {
    grid-row: span 2;
    min-height: 460px;
  }

  .section-{{ section.id }} .nvpromo-card__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
    transform: scale(1.01);
    transition: transform .45s ease;
  }

  .section-{{ section.id }} .nvpromo-card:hover .nvpromo-card__image {
    transform: scale(1.06);
  }

  .section-{{ section.id }} .nvpromo-card__shade {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(90deg, rgba(16,35,28,.88), rgba(16,35,28,.36));
  }

  .section-{{ section.id }} .nvpromo-card:not(.is-large) .nvpromo-card__shade {
    background: linear-gradient(180deg, rgba(16,35,28,.72), rgba(16,35,28,.42));
  }

  .section-{{ section.id }} .nvpromo-card__content {
    height: 100%;
    max-width: 520px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(22px, 4vw, 36px);
    color: #fff;
  }

  .section-{{ section.id }} .nvpromo-card span {
    width: fit-content;
    border-radius: 999px;
    background: rgba(255,255,255,.14);
    color: #fff;
    padding: 7px 11px;
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .08em;
  }

  .section-{{ section.id }} .nvpromo-card h3 {
    margin: 14px 0 0;
    color: #fff;
    font-size: {{ section.settings.card_heading_size }}px;
    line-height: 1.05;
  }

  .section-{{ section.id }} .nvpromo-card p {
    margin: 12px 0 0;
    color: rgba(255,255,255,.84);
    font-size: 16px;
    line-height: 1.5;
  }

  .section-{{ section.id }} .nvpromo-card a {
    width: fit-content;
    margin-top: 20px;
    border-radius: 8px;
    background: #fff;
    color: var(--ink);
    padding: 12px 16px;
    font-weight: 900;
    text-decoration: none;
  }

  @media (max-width: 820px) {
    .section-{{ section.id }} .nvpromo-grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .section-{{ section.id }} .nvpromo-card.is-large {
      min-height: 360px;
    }
  }

  @media (max-width: 640px) {
    .section-{{ section.id }} .nvpromo-shell {
      width: calc(100% - 24px);
    }
  }
</style>

{% schema %}
{
  "name": "NV promos premium",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Etiqueta", "default": "Ofertas y rutinas" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Compra bienestar por necesidad" },
    { "type": "textarea", "id": "text", "label": "Texto", "default": "Un home más comercial, visual y directo para que el cliente encuentre rápido lo que necesita." },
    { "type": "range", "id": "heading_size", "label": "Tamaño título", "min": 28, "max": 56, "step": 1, "unit": "px", "default": 42 },
    { "type": "range", "id": "card_heading_size", "label": "Tamaño títulos de banners", "min": 22, "max": 44, "step": 1, "unit": "px", "default": 32 },
    { "type": "color", "id": "background", "label": "Fondo", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Color acento", "default": "#155b3d" },
    { "type": "range", "id": "padding_top", "label": "Espacio superior", "min": 32, "max": 120, "step": 4, "unit": "px", "default": 76 },
    { "type": "range", "id": "padding_bottom", "label": "Espacio inferior", "min": 32, "max": 120, "step": 4, "unit": "px", "default": 84 }
  ],
  "blocks": [
    {
      "type": "promo",
      "name": "Banner",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagen" },
        { "type": "text", "id": "image_alt", "label": "Texto alternativo" },
        { "type": "text", "id": "badge", "label": "Etiqueta", "default": "Selección Novaren" },
        { "type": "text", "id": "heading", "label": "Título", "default": "Rutina digestiva" },
        { "type": "textarea", "id": "text", "label": "Texto", "default": "Productos y hábitos para acompañar tu bienestar diario con una compra clara y segura." },
        { "type": "text", "id": "button_label", "label": "Botón", "default": "Ver productos" },
        { "type": "url", "id": "button_link", "label": "Enlace" }
      ]
    }
  ],
  "presets": [
    {
      "name": "NV promos premium",
      "blocks": [
        { "type": "promo", "settings": { "badge": "Más buscado", "heading": "Bienestar digestivo", "button_label": "Comprar ahora" } },
        { "type": "promo", "settings": { "badge": "Combos", "heading": "Ahorra comprando en kit", "button_label": "Ver combos" } },
        { "type": "promo", "settings": { "badge": "Guías", "heading": "Hábitos saludables", "button_label": "Leer blog" } }
      ]
    }
  ]
}
{% endschema %}
