{% liquid
  assign product_form_id = 'ProductForm-' | append: section.id
%}

<section class="nvp-product section-{{ section.id }}">
  <div class="nvp-shell nvp-product__grid">
    <div class="nvp-product__media-column">
      <div class="nvp-product__gallery" data-nvp-gallery="{{ section.id }}">
      {% if product.media.size > 1 and section.settings.show_thumbnails %}
        <div class="nvp-thumbs" aria-label="Imágenes del producto">
          {% for media in product.media limit: section.settings.media_stack_limit %}
            {% if media.media_type == 'image' %}
              <button
                type="button"
                class="nvp-thumb {% if forloop.first %}is-active{% endif %}"
                data-nvp-thumb
                data-full="{{ media | image_url: width: 1600 }}"
                data-alt="{{ media.alt | default: product.title | escape }}"
                aria-label="Ver imagen {{ forloop.index }} de {{ product.title | escape }}"
                {% if forloop.first %}aria-current="true"{% endif %}
              >
                {{
                  media
                  | image_url: width: 180
                  | image_tag:
                    widths: '90, 140, 180',
                    sizes: '74px',
                    loading: 'lazy',
                    class: 'nvp-thumb__image',
                    alt: media.alt | default: product.title
                }}
              </button>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

      <div class="nvp-product__media">
        {% if product.featured_media != blank %}
          {{
            product.featured_media
            | image_url: width: 1600
            | image_tag:
              widths: '480, 720, 960, 1200, 1600',
              sizes: '(min-width: 990px) 48vw, 100vw',
              loading: 'eager',
              fetchpriority: 'high',
              class: 'nvp-product__image',
              data-nvp-main-image: section.id,
              alt: product.featured_media.alt | default: product.title
          }}
        {% endif %}
      </div>
      </div>

      {% if section.settings.show_info_accordions %}
        <div class="nvp-accordions nvp-accordions--media{% if section.settings.hide_accordions_on_mobile %} nvp-mobile-hide{% endif %}">
          {% if section.settings.accordion_1_title != blank %}
            <details open>
              <summary>{{ section.settings.accordion_1_title }}</summary>
              <div>{{ section.settings.accordion_1_text }}</div>
            </details>
          {% endif %}
          {% if section.settings.accordion_2_title != blank %}
            <details>
              <summary>{{ section.settings.accordion_2_title }}</summary>
              <div>{{ section.settings.accordion_2_text }}</div>
            </details>
          {% endif %}
          {% if section.settings.accordion_3_title != blank %}
            <details>
              <summary>{{ section.settings.accordion_3_title }}</summary>
              <div>{{ section.settings.accordion_3_text }}</div>
            </details>
          {% endif %}
          {% if section.settings.accordion_4_title != blank %}
            <details>
              <summary>{{ section.settings.accordion_4_title }}</summary>
              <div>{{ section.settings.accordion_4_text }}</div>
            </details>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="nvp-product__info">
      {% if section.settings.stock_label != blank %}
        <div class="nvp-stock">{{ section.settings.stock_label }}</div>
      {% endif %}
      <p class="nvp-eyebrow">{{ section.settings.eyebrow | default: product.type }}</p>
      <h1>
        {% if section.settings.custom_title != blank %}
          {{ section.settings.custom_title }}
        {% else %}
          {{ product.title }}
        {% endif %}
      </h1>
      <div class="nvp-price">{{ product.selected_or_first_available_variant.price | money }}</div>

      {% if section.settings.show_rating_summary %}
        <div class="nvp-rating-summary" aria-label="{{ section.settings.rating_summary_text }}">
          <span>★★★★★</span>
          <strong>{{ section.settings.rating_summary_text }}</strong>
        </div>
      {% endif %}

      {% if section.settings.show_top_summary %}
        <div class="nvp-summary">
          {% if section.settings.custom_summary != blank %}
            {{ section.settings.custom_summary }}
          {% elsif product.description != blank %}
            {{ product.description | strip_html | truncatewords: section.settings.summary_words }}
          {% else %}
            {{ section.settings.fallback_summary }}
          {% endif %}
        </div>
      {% endif %}

      <div class="nvp-bullets">
        {% if section.settings.bullet_1 != blank %}<p><span>✓</span>{{ section.settings.bullet_1 }}</p>{% endif %}
        {% if section.settings.bullet_2 != blank %}<p><span>✓</span>{{ section.settings.bullet_2 }}</p>{% endif %}
        {% if section.settings.bullet_3 != blank %}<p><span>✓</span>{{ section.settings.bullet_3 }}</p>{% endif %}
        {% if section.settings.bullet_4 != blank %}<p><span>✓</span>{{ section.settings.bullet_4 }}</p>{% endif %}
      </div>

      {% if section.settings.show_conversion_panel %}
        <div class="nvp-conversion">
          <div class="nvp-store">
            <div class="nvp-store__seal" aria-hidden="true">
              <svg viewBox="0 0 24 24" role="img">
                <path d="M12 2.8 14.6 5l3.4-.2 1.1 3.2 2.6 2.1-1.4 3.1.7 3.3-3 1.7-1.7 3-3.3-.7-3.1 1.4-2.1-2.6-3.2-1.1.2-3.4L2.8 12 5 9.4l-.2-3.4L8 4.9l2.1-2.6 3.1 1.4Z"/>
                <path d="m8.4 12.2 2.2 2.2 5-5"/>
              </svg>
            </div>
            <div>
              {% if section.settings.trust_kicker != blank %}
                <span>{{ section.settings.trust_kicker }}</span>
              {% endif %}
              {% if section.settings.trust_title != blank %}
                <strong>{{ section.settings.trust_title }}</strong>
              {% endif %}
              {% if section.settings.trust_text != blank %}
                <p>{{ section.settings.trust_text }}</p>
              {% endif %}
            </div>
          </div>

          <div class="nvp-trustbar" aria-hidden="true">
            <i style="width: {{ section.settings.trust_score_percent }}%;"></i>
          </div>

          <div class="nvp-metrics">
            <div>
              <strong>{{ section.settings.metric_1_value }}</strong>
              <span>{{ section.settings.metric_1_label }}</span>
            </div>
            <div>
              <strong>{{ section.settings.metric_2_value }}</strong>
              <span>{{ section.settings.metric_2_label }}</span>
            </div>
            <div>
              <strong>{{ section.settings.metric_3_value }}</strong>
              <span>{{ section.settings.metric_3_label }}</span>
            </div>
          </div>
        </div>

        <div class="nvp-benefits">
          {% if section.settings.benefit_1 != blank %}
            <div>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7h11v8H3z"/><path d="M14 10h4l3 3v2h-7z"/><path d="M7 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm10 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/></svg>
              <div class="nvp-benefit-text">{{ section.settings.benefit_1 }}</div>
            </div>
          {% endif %}
          {% if section.settings.benefit_2 != blank %}
            <div>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 5 6v5c0 4.4 2.8 8.4 7 10 4.2-1.6 7-5.6 7-10V6z"/><path d="m8.8 12.2 2.1 2.1 4.5-4.6"/></svg>
              <div class="nvp-benefit-text">{{ section.settings.benefit_2 }}</div>
            </div>
          {% endif %}
          {% if section.settings.benefit_3 != blank %}
            <div>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16v12H4z"/><path d="M4 9h16"/><path d="M8 14h4"/></svg>
              <div class="nvp-benefit-text">{{ section.settings.benefit_3 }}</div>
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% form 'product', product, class: 'nvp-form', id: product_form_id %}
        {% if product.has_only_default_variant %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        {% else %}
          <label for="Variant-{{ section.id }}">{{ section.settings.variant_label }}</label>
          <select id="Variant-{{ section.id }}" name="id">
            {% for variant in product.variants %}
              <option
                value="{{ variant.id }}"
                {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
                {% unless variant.available %}disabled{% endunless %}
              >
                {{ variant.title }}{% unless variant.available %} - Agotado{% endunless %}
              </option>
            {% endfor %}
          </select>
        {% endif %}

        {% if section.settings.show_quantity %}
          <label for="Quantity-{{ section.id }}">{{ section.settings.quantity_label }}</label>
          <input id="Quantity-{{ section.id }}" type="number" name="quantity" value="1" min="1">
        {% endif %}

        <button type="submit" name="add" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
          {% if product.selected_or_first_available_variant.available %}
            {{ section.settings.button_label }}
          {% else %}
            {{ section.settings.sold_out_label }}
          {% endif %}
        </button>
        {% if section.settings.cta_note != blank %}
          <p class="nvp-cta-note">{{ section.settings.cta_note }}</p>
        {% endif %}
      {% endform %}

      <div class="nvp-promises{% if section.settings.hide_promises_on_mobile %} nvp-mobile-hide{% endif %}">
        {% for block in section.blocks %}
          {% if block.type == 'promise' %}
            <span {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  {% if section.settings.show_full_description_below and product.description != blank %}
    <div class="nvp-shell nvp-description">
      {% if section.settings.description_eyebrow != blank %}
        <p class="nvp-eyebrow">{{ section.settings.description_eyebrow }}</p>
      {% endif %}
      {% if section.settings.description_heading != blank %}
        <h2>{{ section.settings.description_heading }}</h2>
      {% endif %}
      <div class="nvp-description__body">
        {{ product.description }}
      </div>
    </div>
  {% endif %}

  <div class="nvp-shell nvp-details{% if section.settings.hide_detail_blocks_on_mobile %} nvp-mobile-hide{% endif %}">
    {% for block in section.blocks %}
      {% if block.type == 'detail' %}
        <article {{ block.shopify_attributes }}>
          <p class="nvp-eyebrow">{{ block.settings.eyebrow }}</p>
          <h2>{{ block.settings.heading }}</h2>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.settings.show_mobile_sticky_cta %}
    <div class="nvp-mobile-cta" aria-label="Compra rápida">
      <div>
        <span>{{ section.settings.mobile_sticky_kicker }}</span>
        <strong>{{ product.selected_or_first_available_variant.price | money }}</strong>
      </div>
      <button
        type="submit"
        name="add"
        form="{{ product_form_id }}"
        {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
      >
        {% if product.selected_or_first_available_variant.available %}
          {{ section.settings.mobile_sticky_label }}
        {% else %}
          {{ section.settings.sold_out_label }}
        {% endif %}
      </button>
    </div>
  {% endif %}
</section>

<style>
  .section-{{ section.id }} {
    --ink: #10231c;
    --muted: #657067;
    --green: {{ section.settings.accent_color }};
    --line: rgba(16, 35, 28, .12);
    color: var(--ink);
    background:
      radial-gradient(circle at 16% 8%, rgba(21, 91, 61, .08), transparent 26%),
      linear-gradient(180deg, {{ section.settings.background_top }}, {{ section.settings.background_bottom }});
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow-x: hidden;
  }

  .section-{{ section.id }} .nvp-shell {
    width: calc(100% - 32px);
    max-width: 1080px;
    margin-inline: auto;
  }

  .section-{{ section.id }} .nvp-product__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.04fr) minmax(360px, .86fr);
    gap: clamp(22px, 4vw, 44px);
    align-items: start;
  }

  .section-{{ section.id }} .nvp-product__media-column {
    display: grid;
    gap: 18px;
    align-self: start;
  }

  .section-{{ section.id }} .nvp-product__gallery {
    display: grid;
    grid-template-columns: {% if product.media.size > 1 and section.settings.show_thumbnails %}86px minmax(0, 1fr){% else %}minmax(0, 1fr){% endif %};
    gap: 16px;
    align-self: start;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    padding: 16px;
    box-shadow: 0 20px 64px rgba(16, 35, 28, .1);
  }

  .section-{{ section.id }} .nvp-product__media {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: 8px;
    background: #fff;
    overflow: hidden;
  }

  .section-{{ section.id }} .nvp-product__image {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.media_fit }};
    display: block;
    padding: {{ section.settings.media_padding }}px;
    background: #fff;
  }

  .section-{{ section.id }} .nvp-thumbs {
    display: grid;
    align-content: start;
    gap: 10px;
    max-height: min(620px, 72vh);
    overflow-y: auto;
    padding-right: 2px;
  }

  .section-{{ section.id }} .nvp-thumb {
    width: 74px;
    aspect-ratio: 1 / 1;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    padding: 0;
    overflow: hidden;
    cursor: pointer;
    opacity: .68;
    transition: opacity .2s ease, transform .2s ease, border-color .2s ease, box-shadow .2s ease;
  }

  .section-{{ section.id }} .nvp-thumb:hover,
  .section-{{ section.id }} .nvp-thumb.is-active {
    opacity: 1;
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--green) 45%, var(--line));
    box-shadow: 0 10px 24px rgba(16, 35, 28, .12);
  }

  .section-{{ section.id }} .nvp-thumb__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .section-{{ section.id }} .nvp-product__info {
    position: sticky;
    top: 104px;
    border: 1px solid rgba(16, 35, 28, .1);
    border-radius: 8px;
    background: rgba(255,255,255,.94);
    padding: clamp(22px, 3vw, 30px);
    box-shadow: 0 20px 66px rgba(16, 35, 28, .1);
    backdrop-filter: blur(14px);
  }

  .section-{{ section.id }} .nvp-stock {
    width: fit-content;
    margin-bottom: 12px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--green) 10%, #ffffff);
    color: var(--green);
    padding: 7px 11px;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .04em;
    text-transform: uppercase;
  }

  .section-{{ section.id }} .nvp-eyebrow {
    margin: 0 0 12px;
    color: var(--green);
    font-size: {{ section.settings.eyebrow_font_size }}px;
    font-weight: 850;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .section-{{ section.id }} h1 {
    margin: 0;
    color: var(--ink);
    font-size: {{ section.settings.title_font_size_desktop }}px;
    line-height: {{ section.settings.title_line_height }}%;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .section-{{ section.id }} .nvp-price {
    margin-top: 18px;
    color: var(--green);
    font-size: {{ section.settings.price_font_size }}px;
    font-weight: 900;
  }

  .section-{{ section.id }} .nvp-rating-summary {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
    color: var(--green);
    font-size: 13px;
  }

  .section-{{ section.id }} .nvp-rating-summary span {
    letter-spacing: 1px;
  }

  .section-{{ section.id }} .nvp-rating-summary strong {
    color: var(--muted);
    font-weight: 850;
  }

  .section-{{ section.id }} .nvp-summary {
    margin-top: 16px;
    color: var(--muted);
    font-size: {{ section.settings.summary_font_size_desktop }}px;
    line-height: {{ section.settings.summary_line_height }}%;
  }

  .section-{{ section.id }} .nvp-summary p {
    margin: 0 0 12px;
  }

  .section-{{ section.id }} .nvp-summary p:last-child {
    margin-bottom: 0;
  }

  .section-{{ section.id }} .nvp-bullets {
    display: grid;
    gap: 9px;
    margin-top: 18px;
  }

  .section-{{ section.id }} .nvp-bullets p {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 9px;
    align-items: start;
    margin: 0;
    color: var(--ink);
    font-size: 15px;
    line-height: 1.45;
  }

  .section-{{ section.id }} .nvp-bullets span {
    width: 20px;
    height: 20px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: var(--green);
    color: #fff;
    font-size: 12px;
    font-weight: 900;
    line-height: 1;
  }

  .section-{{ section.id }} .nvp-conversion {
    margin-top: 26px;
    border: 1px solid rgba(16, 35, 28, .1);
    border-radius: 8px;
    background:
      radial-gradient(circle at 18% 0%, rgba(21, 91, 61, .1), transparent 32%),
      linear-gradient(180deg, rgba(255,255,255,.96), rgba(255,255,255,.84));
    padding: 18px;
    box-shadow: 0 18px 52px rgba(16, 35, 28, .08);
  }

  .section-{{ section.id }} .nvp-store {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 14px;
    align-items: center;
  }

  .section-{{ section.id }} .nvp-store__seal {
    width: 52px;
    height: 52px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: color-mix(in srgb, var(--green) 12%, #ffffff);
    color: var(--green);
  }

  .section-{{ section.id }} .nvp-store__seal svg,
  .section-{{ section.id }} .nvp-benefits svg {
    width: 24px;
    height: 24px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .section-{{ section.id }} .nvp-store span {
    display: block;
    color: var(--muted);
    font-size: 12px;
    font-weight: 800;
  }

  .section-{{ section.id }} .nvp-store strong {
    display: block;
    margin-top: 2px;
    color: var(--green);
    font-size: {{ section.settings.conversion_title_font_size }}px;
    line-height: 1.18;
  }

  .section-{{ section.id }} .nvp-store p {
    margin: 3px 0 0;
    color: var(--muted);
    font-size: {{ section.settings.conversion_text_font_size }}px;
    line-height: 1.35;
  }

  .section-{{ section.id }} .nvp-trustbar {
    height: 8px;
    margin-top: 16px;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(245, 96, 74, .16), rgba(255, 211, 104, .18), rgba(21, 91, 61, .18));
    overflow: hidden;
  }

  .section-{{ section.id }} .nvp-trustbar i {
    display: block;
    height: 100%;
    max-width: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #8fd6ad, var(--green));
  }

  .section-{{ section.id }} .nvp-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 14px;
    border-top: 1px solid var(--line);
  }

  .section-{{ section.id }} .nvp-metrics div {
    padding: 14px 10px 0;
    text-align: center;
  }

  .section-{{ section.id }} .nvp-metrics div + div {
    border-left: 1px solid var(--line);
  }

  .section-{{ section.id }} .nvp-metrics strong,
  .section-{{ section.id }} .nvp-metrics span {
    display: block;
  }

  .section-{{ section.id }} .nvp-metrics strong {
    color: var(--ink);
    font-size: {{ section.settings.metric_value_font_size }}px;
    line-height: 1.05;
  }

  .section-{{ section.id }} .nvp-metrics span {
    margin-top: 5px;
    color: var(--muted);
    font-size: {{ section.settings.metric_label_font_size }}px;
    line-height: 1.25;
  }

  .section-{{ section.id }} .nvp-benefits {
    display: grid;
    gap: 10px;
    margin-top: 14px;
    border-radius: 8px;
    background: #f4f6f5;
    padding: 16px;
  }

  .section-{{ section.id }} .nvp-benefits div {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 10px;
    align-items: start;
    color: var(--green);
  }

  .section-{{ section.id }} .nvp-benefits svg {
    width: 19px;
    height: 19px;
    margin-top: 1px;
  }

  .section-{{ section.id }} .nvp-benefit-text {
    color: var(--ink);
    font-size: {{ section.settings.benefit_font_size }}px;
    line-height: 1.42;
  }

  .section-{{ section.id }} .nvp-benefit-text p {
    margin: 0;
    color: var(--ink);
  }

  .section-{{ section.id }} .nvp-benefit-text strong {
    font-weight: 900;
  }

  .section-{{ section.id }} .nvp-form {
    display: grid;
    gap: 12px;
    margin-top: 18px;
  }

  .section-{{ section.id }} .nvp-form label {
    color: var(--ink);
    font-size: {{ section.settings.form_label_font_size }}px;
    font-weight: 850;
  }

  .section-{{ section.id }} .nvp-form select,
  .section-{{ section.id }} .nvp-form input {
    width: 100%;
    min-height: 48px;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0 14px;
    background: #fff;
    color: var(--ink);
    font: inherit;
  }

  .section-{{ section.id }} .nvp-form button {
    min-height: 62px;
    border: 0;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--green), #0d3f2c);
    color: #fff;
    font: inherit;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 900;
    cursor: pointer;
    box-shadow: 0 18px 42px rgba(21, 91, 61, .28);
    transition: transform .22s ease, box-shadow .22s ease, filter .22s ease;
  }

  .section-{{ section.id }} .nvp-form button:hover {
    transform: translateY(-2px);
    filter: saturate(1.08) brightness(1.02);
    box-shadow: 0 22px 48px rgba(21, 91, 61, .32);
  }

  .section-{{ section.id }} .nvp-form button:disabled {
    opacity: .55;
    cursor: not-allowed;
  }

  .section-{{ section.id }} .nvp-cta-note {
    margin: -4px 0 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.4;
    text-align: center;
  }

  .section-{{ section.id }} .nvp-accordions {
    margin-top: 18px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    overflow: hidden;
  }

  .section-{{ section.id }} .nvp-accordions--media {
    margin-top: 0;
    background: rgba(255,255,255,.92);
