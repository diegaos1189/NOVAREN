<section class="nvp-product section-{{ section.id }}">
  <div class="nvp-shell nvp-product__grid">
    <div class="nvp-product__media">
      {% if product.featured_media != blank %}
        {{
          product.featured_media
          | image_url: width: 1400
          | image_tag:
            widths: '480, 720, 960, 1400',
            sizes: '(min-width: 990px) 52vw, 100vw',
            loading: 'eager',
            fetchpriority: 'high',
            class: 'nvp-product__image',
            alt: product.featured_media.alt | default: product.title
        }}
      {% endif %}
    </div>

    <div class="nvp-product__info">
      <p class="nvp-eyebrow">{{ section.settings.eyebrow | default: product.type }}</p>
      <h1>
        {% if section.settings.custom_title != blank %}
          {{ section.settings.custom_title }}
        {% else %}
          {{ product.title }}
        {% endif %}
      </h1>
      <div class="nvp-price">{{ product.selected_or_first_available_variant.price | money }}</div>

      <div class="nvp-summary">
        {% if section.settings.custom_summary != blank %}
          {{ section.settings.custom_summary }}
        {% elsif product.description != blank %}
          {{ product.description | strip_html | truncatewords: section.settings.summary_words }}
        {% else %}
          {{ section.settings.fallback_summary }}
        {% endif %}
      </div>

      {% form 'product', product, class: 'nvp-form' %}
        {% if product.has_only_default_variant %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        {% else %}
          <label for="Variant-{{ section.id }}">{{ section.settings.variant_label }}</label>
          <select id="Variant-{{ section.id }}" name="id">
            {% for variant in product.variants %}
              <option
                value="{{ variant.id }}"
                {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
                {% unless variant.available %}disabled{% endunless %}
              >
                {{ variant.title }}{% unless variant.available %} - Agotado{% endunless %}
              </option>
            {% endfor %}
          </select>
        {% endif %}

        {% if section.settings.show_quantity %}
          <label for="Quantity-{{ section.id }}">{{ section.settings.quantity_label }}</label>
          <input id="Quantity-{{ section.id }}" type="number" name="quantity" value="1" min="1">
        {% endif %}

        <button type="submit" name="add" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
          {% if product.selected_or_first_available_variant.available %}
            {{ section.settings.button_label }}
          {% else %}
            {{ section.settings.sold_out_label }}
          {% endif %}
        </button>
      {% endform %}

      <div class="nvp-promises">
        {% for block in section.blocks %}
          {% if block.type == 'promise' %}
            <span {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="nvp-shell nvp-details">
    {% for block in section.blocks %}
      {% if block.type == 'detail' %}
        <article {{ block.shopify_attributes }}>
          <p class="nvp-eyebrow">{{ block.settings.eyebrow }}</p>
          <h2>{{ block.settings.heading }}</h2>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endif %}
    {% endfor %}
  </div>
</section>

<style>
  .section-{{ section.id }} {
    --ink: #10231c;
    --muted: #657067;
    --green: {{ section.settings.accent_color }};
    --line: rgba(16, 35, 28, .12);
    color: var(--ink);
    background: linear-gradient(180deg, {{ section.settings.background_top }}, {{ section.settings.background_bottom }});
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow-x: hidden;
  }

  .section-{{ section.id }} .nvp-shell {
    width: calc(100% - 32px);
    max-width: 1180px;
    margin-inline: auto;
  }

  .section-{{ section.id }} .nvp-product__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(340px, .86fr);
    gap: clamp(28px, 6vw, 76px);
    align-items: center;
  }

  .section-{{ section.id }} .nvp-product__media {
    aspect-ratio: 1 / 1;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    overflow: hidden;
    box-shadow: 0 24px 70px rgba(16, 35, 28, .1);
  }

  .section-{{ section.id }} .nvp-product__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    padding: clamp(18px, 4vw, 44px);
  }

  .section-{{ section.id }} .nvp-eyebrow {
    margin: 0 0 12px;
    color: var(--green);
    font-size: {{ section.settings.eyebrow_font_size }}px;
    font-weight: 850;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .section-{{ section.id }} h1 {
    margin: 0;
    color: var(--ink);
    font-size: {{ section.settings.title_font_size_desktop }}px;
    line-height: {{ section.settings.title_line_height }}%;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .section-{{ section.id }} .nvp-price {
    margin-top: 22px;
    color: var(--green);
    font-size: {{ section.settings.price_font_size }}px;
    font-weight: 900;
  }

  .section-{{ section.id }} .nvp-summary {
    margin-top: 18px;
    color: var(--muted);
    font-size: {{ section.settings.summary_font_size_desktop }}px;
    line-height: {{ section.settings.summary_line_height }}%;
  }

  .section-{{ section.id }} .nvp-summary p {
    margin: 0 0 12px;
  }

  .section-{{ section.id }} .nvp-summary p:last-child {
    margin-bottom: 0;
  }

  .section-{{ section.id }} .nvp-form {
    display: grid;
    gap: 12px;
    margin-top: 28px;
  }

  .section-{{ section.id }} .nvp-form label {
    color: var(--ink);
    font-size: {{ section.settings.form_label_font_size }}px;
    font-weight: 850;
  }

  .section-{{ section.id }} .nvp-form select,
  .section-{{ section.id }} .nvp-form input {
    width: 100%;
    min-height: 48px;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0 14px;
    background: #fff;
    color: var(--ink);
    font: inherit;
  }

  .section-{{ section.id }} .nvp-form button {
    min-height: 56px;
    border: 0;
    border-radius: 8px;
    background: var(--green);
    color: #fff;
    font: inherit;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 900;
    cursor: pointer;
    box-shadow: 0 18px 42px rgba(21, 91, 61, .22);
    transition: transform .22s ease, background-color .22s ease;
  }

  .section-{{ section.id }} .nvp-form button:hover {
    transform: translateY(-2px);
    background: #0d422b;
  }

  .section-{{ section.id }} .nvp-form button:disabled {
    opacity: .55;
    cursor: not-allowed;
  }

  .section-{{ section.id }} .nvp-promises {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
  }

  .section-{{ section.id }} .nvp-promises span {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 8px 12px;
    background: #fff;
    color: var(--muted);
    font-size: {{ section.settings.promise_font_size }}px;
    font-weight: 850;
  }

  .section-{{ section.id }} .nvp-details {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    margin-top: clamp(46px, 7vw, 86px);
  }

  .section-{{ section.id }} .nvp-details article {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255,255,255,.82);
    padding: clamp(22px, 4vw, 34px);
    box-shadow: 0 20px 60px rgba(16, 35, 28, .08);
  }

  .section-{{ section.id }} .nvp-details h2 {
    margin: 0;
    color: var(--ink);
    font-size: {{ section.settings.detail_title_font_size }}px;
    line-height: {{ section.settings.detail_title_line_height }}%;
    letter-spacing: 0;
  }

  .section-{{ section.id }} .nvp-details p:not(.nvp-eyebrow) {
    margin: 14px 0 0;
    color: var(--muted);
    font-size: {{ section.settings.detail_text_font_size }}px;
    line-height: {{ section.settings.detail_text_line_height }}%;
  }

  @media (max-width: 989px) {
    .section-{{ section.id }} .nvp-product__grid,
    .section-{{ section.id }} .nvp-details {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (max-width: 640px) {
    .section-{{ section.id }} .nvp-shell {
      width: calc(100% - 24px);
      max-width: 330px;
      margin-left: 12px;
      margin-right: auto;
    }

    .section-{{ section.id }} h1 {
      font-size: {{ section.settings.title_font_size_mobile }}px;
    }

    .section-{{ section.id }} .nvp-summary {
      font-size: {{ section.settings.summary_font_size_mobile }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Novaren producto premium",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Etiqueta superior", "default": "Bienestar" },
    { "type": "text", "id": "custom_title", "label": "Título personalizado", "info": "Déjalo vacío para usar el título real del producto." },
    { "type": "richtext", "id": "custom_summary", "label": "Párrafo personalizado", "info": "Déjalo vacío para usar la descripción del producto." },
    { "type": "textarea", "id": "fallback_summary", "label": "Resumen si no hay descripción", "default": "Producto seleccionado por Novaren para acompañar rutinas saludables, autocuidado y bienestar diario." },
    { "type": "range", "id": "summary_words", "label": "Palabras del resumen", "min": 18, "max": 80, "step": 2, "default": 42 },
    { "type": "header", "content": "Tamaños de texto" },
    { "type": "range", "id": "eyebrow_font_size", "label": "Etiqueta superior", "min": 10, "max": 18, "step": 1, "unit": "px", "default": 12 },
    { "type": "range", "id": "title_font_size_desktop", "label": "Título en escritorio", "min": 34, "max": 76, "step": 1, "unit": "px", "default": 54 },
    { "type": "range", "id": "title_font_size_mobile", "label": "Título en móvil", "min": 26, "max": 48, "step": 1, "unit": "px", "default": 32 },
    { "type": "range", "id": "title_line_height", "label": "Interlineado del título", "min": 90, "max": 125, "step": 1, "unit": "%", "default": 104 },
    { "type": "range", "id": "price_font_size", "label": "Precio", "min": 20, "max": 42, "step": 1, "unit": "px", "default": 34 },
    { "type": "range", "id": "summary_font_size_desktop", "label": "Párrafo en escritorio", "min": 14, "max": 24, "step": 1, "unit": "px", "default": 17 },
    { "type": "range", "id": "summary_font_size_mobile", "label": "Párrafo en móvil", "min": 13, "max": 21, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "summary_line_height", "label": "Interlineado del párrafo", "min": 130, "max": 190, "step": 5, "unit": "%", "default": 165 },
    { "type": "range", "id": "button_font_size", "label": "Botón de compra", "min": 14, "max": 22, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "promise_font_size", "label": "Promesas de confianza", "min": 11, "max": 18, "step": 1, "unit": "px", "default": 13 },
    { "type": "range", "id": "form_label_font_size", "label": "Etiquetas del formulario", "min": 11, "max": 17, "step": 1, "unit": "px", "default": 13 },
    { "type": "range", "id": "detail_title_font_size", "label": "Títulos de bloques inferiores", "min": 22, "max": 42, "step": 1, "unit": "px", "default": 30 },
    { "type": "range", "id": "detail_title_line_height", "label": "Interlineado de títulos inferiores", "min": 95, "max": 130, "step": 1, "unit": "%", "default": 108 },
    { "type": "range", "id": "detail_text_font_size", "label": "Párrafos de bloques inferiores", "min": 14, "max": 22, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "detail_text_line_height", "label": "Interlineado de bloques inferiores", "min": 130, "max": 190, "step": 5, "unit": "%", "default": 165 },
    { "type": "header", "content": "Formulario y compra" },
    { "type": "text", "id": "variant_label", "label": "Etiqueta variantes", "default": "Presentación" },
    { "type": "checkbox", "id": "show_quantity", "label": "Mostrar cantidad", "default": true },
    { "type": "text", "id": "quantity_label", "label": "Etiqueta cantidad", "default": "Cantidad" },
    { "type": "text", "id": "button_label", "label": "Texto botón compra", "default": "Agregar al carrito" },
    { "type": "text", "id": "sold_out_label", "label": "Texto agotado", "default": "Agotado" },
    { "type": "color", "id": "accent_color", "label": "Color acento", "default": "#155b3d" },
    { "type": "color", "id": "background_top", "label": "Fondo superior", "default": "#fbfaf5" },
    { "type": "color", "id": "background_bottom", "label": "Fondo inferior", "default": "#ffffff" },
    { "type": "range", "id": "padding_top", "label": "Espacio superior", "min": 20, "max": 100, "step": 4, "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Espacio inferior", "min": 40, "max": 140, "step": 4, "default": 96 }
  ],
  "blocks": [
    {
      "type": "promise",
      "name": "Promesa de confianza",
      "settings": [
        { "type": "text", "id": "text", "label": "Texto", "default": "Compra segura" }
      ]
    },
    {
      "type": "detail",
      "name": "Bloque informativo",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Etiqueta", "default": "Rutina Novaren" },
        { "type": "text", "id": "heading", "label": "Título", "default": "Bienestar pensado para tu día a día" },
        { "type": "textarea", "id": "text", "label": "Texto", "default": "Integra este producto como complemento de hábitos simples: buena hidratación, alimentación equilibrada, movimiento suave y descanso." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Novaren producto premium",
      "blocks": [
        { "type": "promise", "settings": { "text": "Compra segura" } },
        { "type": "promise", "settings": { "text": "Envíos en Colombia" } },
        { "type": "promise", "settings": { "text": "Atención personalizada" } },
        { "type": "detail", "settings": { "eyebrow": "Rutina Novaren", "heading": "Bienestar pensado para tu día a día", "text": "Integra este producto como complemento de hábitos simples: buena hidratación, alimentación equilibrada, movimiento suave y descanso. Si tienes una condición médica, estás en embarazo, lactancia o tomas medicamentos, consulta con un profesional de salud." } },
        { "type": "detail", "settings": { "eyebrow": "Guía rápida", "heading": "Cómo elegir con confianza", "text": "Revisa la descripción, presentación y modo de uso del producto. Novaren selecciona productos para que comprar bienestar online sea claro, cómodo y seguro." } }
      ]
    }
  ]
}
{% endschema %}
