</style>

<script>
  (() => {
    const root = document.querySelector('[data-nvp-gallery="{{ section.id }}"]');
    if (!root) return;

    const mainImage = root.querySelector('[data-nvp-main-image="{{ section.id }}"]');
    const thumbs = [...root.querySelectorAll('[data-nvp-thumb]')];
    if (!mainImage || !thumbs.length) return;

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const nextSrc = thumb.dataset.full;
        const nextAlt = thumb.dataset.alt || mainImage.alt;
        if (!nextSrc) return;

        mainImage.src = nextSrc;
        mainImage.removeAttribute('srcset');
        mainImage.alt = nextAlt;

        thumbs.forEach((item) => {
          item.classList.remove('is-active');
          item.removeAttribute('aria-current');
        });
        thumb.classList.add('is-active');
        thumb.setAttribute('aria-current', 'true');
      });
    });
  })();
</script>

