{% if product.metafields.custom.review != blank %}

<section class="review-section section-{{ section.id }}">

  <div class="page-width">

    <div class="review-accordion">

      <details>
        <summary class="review-title">
          {{ section.settings.title }}
        </summary>

        <div class="review-content">

          <div class="review-short">
            {{ product.metafields.custom.review | strip_html | truncate: 400 }}
          </div>

          <div class="review-full hidden">
            {{ product.metafields.custom.review }}
          </div>

          <button class="review-toggle">
            Leer más
          </button>

        </div>

      </details>

    </div>

  </div>

</section>

{% endif %}

<style>

.review-section {
  margin: 60px 0;
}

.review-accordion {
  max-width: 700px;
  margin: auto;
  border-top: 1px solid rgba(0,0,0,0.1);
  padding-top: 25px;
}

.review-title {
  font-size: 1rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  font-weight: 500;
}

.review-content {
  margin-top: 20px;
  line-height: 1.8;
  font-size: 0.98rem;
}

.review-toggle {
  margin-top: 15px;
  background: none;
  border: none;
  text-decoration: underline;
  cursor: pointer;
  font-size: 0.9rem;
}

.hidden {
  display: none;
}

</style>

<script>

document.addEventListener("DOMContentLoaded", function(){

  document.querySelectorAll(".review-toggle").forEach(function(btn){

    btn.addEventListener("click", function(){

      const container = btn.closest(".review-content");
      const shortText = container.querySelector(".review-short");
      const fullText = container.querySelector(".review-full");

      shortText.classList.toggle("hidden");
      fullText.classList.toggle("hidden");

      btn.textContent =
        btn.textContent === "Leer más"
        ? "Leer menos"
        : "Leer más";

    });

  });

});

</script>

{% schema %}
{
  "name": "Reseña Acordeón",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Reseña"
    }
  ],
  "presets": [
    {
      "name": "Reseña Acordeón"
    }
  ]
}
{% endschema %}
