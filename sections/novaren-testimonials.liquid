<section class="nvt section-{{ section.id }}">
  <div class="nvt-shell">
    <div class="nvt-head">
      {% if section.settings.eyebrow != blank %}
        <p class="nvt-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="nvt-subheading">{{ section.settings.subheading }}</p>
      {% endif %}
      {% if section.settings.rating_text != blank %}
        <div class="nvt-rating">
          <span>{{ section.settings.rating_text }}</span>
          <strong>{{ section.settings.rating_value }}</strong>
          <div aria-label="{{ section.settings.rating_value }} de 5">
            {% for i in (1..5) %}
              <span>★</span>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>

    <div class="nvt-grid">
      {% for block in section.blocks %}
        {% if block.type == 'testimonial' %}
          <article class="nvt-card" {{ block.shopify_attributes }}>
            <div class="nvt-card__top">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 240
                  | image_tag:
                    widths: '96, 144, 192, 240',
                    sizes: '72px',
                    loading: 'lazy',
                    class: 'nvt-avatar',
                    alt: block.settings.image_alt | default: block.settings.name
                }}
              {% else %}
                <div class="nvt-avatar nvt-avatar--initials" aria-hidden="true">
                  {{ block.settings.initials | default: 'NV' }}
                </div>
              {% endif %}

              <div class="nvt-stars" aria-label="{{ block.settings.rating }} de 5">
                {% for i in (1..5) %}
                  <span class="{% if i <= block.settings.rating %}is-active{% endif %}">★</span>
                {% endfor %}
              </div>
            </div>

            {% if block.settings.title != blank %}
              <h3>{{ block.settings.title }}</h3>
            {% endif %}

            {% if block.settings.quote != blank %}
              <p class="nvt-quote">{{ block.settings.quote }}</p>
            {% endif %}

            <div class="nvt-person">
              <strong>{{ block.settings.name }}</strong>
              {% if block.settings.meta != blank %}
                <span>{{ block.settings.meta }}</span>
              {% endif %}
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .section-{{ section.id }} {
    --nvt-ink: {{ section.settings.text_color }};
    --nvt-muted: {{ section.settings.muted_color }};
    --nvt-accent: {{ section.settings.accent_color }};
    --nvt-card: {{ section.settings.card_background }};
    --nvt-line: rgba(16, 35, 28, .12);
    color: var(--nvt-ink);
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} .nvt-shell {
    width: calc(100% - 32px);
    max-width: 1180px;
    margin-inline: auto;
  }

  .section-{{ section.id }} .nvt-head {
    max-width: 760px;
    margin: 0 auto 36px;
    text-align: center;
  }

  .section-{{ section.id }} .nvt-eyebrow {
    margin: 0 0 10px;
    color: var(--nvt-accent);
    font-size: {{ section.settings.eyebrow_font_size }}px;
    font-weight: 850;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .section-{{ section.id }} h2 {
    margin: 0;
    color: var(--nvt-ink);
    font-size: {{ section.settings.heading_font_size }}px;
    line-height: {{ section.settings.heading_line_height }}%;
    letter-spacing: 0;
  }

  .section-{{ section.id }} .nvt-subheading {
    margin: 14px auto 0;
    max-width: 620px;
    color: var(--nvt-muted);
    font-size: {{ section.settings.subheading_font_size }}px;
    line-height: 160%;
  }

  .section-{{ section.id }} .nvt-rating {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    flex-wrap: wrap;
    margin-top: 18px;
    color: var(--nvt-muted);
    font-size: {{ section.settings.rating_font_size }}px;
  }

  .section-{{ section.id }} .nvt-rating strong {
    color: var(--nvt-ink);
    font-weight: 900;
  }

  .section-{{ section.id }} .nvt-rating div,
  .section-{{ section.id }} .nvt-stars {
    display: inline-flex;
    gap: 3px;
  }

  .section-{{ section.id }} .nvt-rating div span,
  .section-{{ section.id }} .nvt-stars span {
    display: grid;
    place-items: center;
    width: 18px;
    height: 18px;
    border-radius: 3px;
    background: var(--nvt-accent);
    color: #fff;
    font-size: 12px;
    line-height: 1;
  }

  .section-{{ section.id }} .nvt-stars span:not(.is-active) {
    background: #d6d9dd;
  }

  .section-{{ section.id }} .nvt-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: {{ section.settings.card_gap }}px;
  }

  .section-{{ section.id }} .nvt-card {
    min-height: 100%;
    border: 1px solid var(--nvt-line);
    border-radius: 8px;
    background: var(--nvt-card);
    padding: {{ section.settings.card_padding }}px;
    text-align: {{ section.settings.card_text_align }};
    box-shadow: 0 18px 50px rgba(16, 35, 28, .08);
  }

  .section-{{ section.id }} .nvt-card__top {
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.card_content_position }};
    gap: 14px;
    margin-bottom: 18px;
  }

  .section-{{ section.id }} .nvt-avatar {
    width: {{ section.settings.image_size }}px;
    height: {{ section.settings.image_size }}px;
    border-radius: 999px;
    object-fit: cover;
    border: 2px solid rgba(255,255,255,.8);
    box-shadow: 0 10px 28px rgba(16, 35, 28, .12);
    flex: 0 0 auto;
  }

  .section-{{ section.id }} .nvt-avatar--initials {
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--nvt-accent) 14%, #ffffff);
    color: var(--nvt-accent);
    font-size: 15px;
    font-weight: 900;
  }

  .section-{{ section.id }} .nvt-card h3 {
    margin: 0;
    color: var(--nvt-ink);
    font-size: {{ section.settings.card_title_font_size }}px;
    line-height: 125%;
    letter-spacing: 0;
  }

  .section-{{ section.id }} .nvt-quote {
    margin: 14px 0 0;
    color: var(--nvt-ink);
    font-size: {{ section.settings.quote_font_size }}px;
    line-height: {{ section.settings.quote_line_height }}%;
  }

  .section-{{ section.id }} .nvt-person {
    margin-top: 20px;
    padding-top: 14px;
    border-top: 1px solid var(--nvt-line);
    color: var(--nvt-muted);
    font-size: {{ section.settings.person_font_size }}px;
  }

  .section-{{ section.id }} .nvt-person strong,
  .section-{{ section.id }} .nvt-person span {
    display: block;
  }

  .section-{{ section.id }} .nvt-person strong {
    color: var(--nvt-ink);
    font-weight: 900;
  }

  .section-{{ section.id }} .nvt-person span {
    margin-top: 3px;
  }

  @media (max-width: 989px) {
    .section-{{ section.id }} .nvt-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .section-{{ section.id }} .nvt-shell {
      width: calc(100% - 24px);
    }

    .section-{{ section.id }} h2 {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }

    .section-{{ section.id }} .nvt-grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .section-{{ section.id }} .nvt-card {
      padding: 22px;
    }
  }
</style>

{% schema %}
{
  "name": "Novaren testimonios",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Etiqueta superior", "default": "Confianza real" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Testimonios de clientes" },
    { "type": "textarea", "id": "subheading", "label": "Párrafo", "default": "Historias editables para mostrar experiencias reales de clientes de Novaren con un tono claro, prudente y confiable." },
    { "type": "text", "id": "rating_text", "label": "Texto de calificación", "default": "Excelente" },
    { "type": "text", "id": "rating_value", "label": "Calificación general", "default": "4.8 / 5" },
    { "type": "header", "content": "Tamaños de texto" },
    { "type": "range", "id": "eyebrow_font_size", "label": "Etiqueta superior", "min": 10, "max": 18, "step": 1, "unit": "px", "default": 12 },
    { "type": "range", "id": "heading_font_size", "label": "Título en escritorio", "min": 26, "max": 52, "step": 1, "unit": "px", "default": 36 },
    { "type": "range", "id": "heading_font_size_mobile", "label": "Título en móvil", "min": 22, "max": 40, "step": 1, "unit": "px", "default": 28 },
    { "type": "range", "id": "heading_line_height", "label": "Interlineado del título", "min": 95, "max": 130, "step": 1, "unit": "%", "default": 112 },
    { "type": "range", "id": "subheading_font_size", "label": "Párrafo superior", "min": 14, "max": 22, "step": 1, "unit": "px", "default": 17 },
    { "type": "range", "id": "rating_font_size", "label": "Calificación general", "min": 13, "max": 20, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "card_title_font_size", "label": "Título del testimonio", "min": 15, "max": 24, "step": 1, "unit": "px", "default": 18 },
    { "type": "range", "id": "quote_font_size", "label": "Texto del testimonio", "min": 14, "max": 22, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "quote_line_height", "label": "Interlineado del testimonio", "min": 130, "max": 190, "step": 5, "unit": "%", "default": 160 },
    { "type": "range", "id": "person_font_size", "label": "Nombre y ciudad", "min": 12, "max": 18, "step": 1, "unit": "px", "default": 14 },
    { "type": "header", "content": "Diseño" },
    { "type": "range", "id": "columns_desktop", "label": "Columnas en escritorio", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "card_gap", "label": "Espacio entre tarjetas", "min": 12, "max": 36, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "card_padding", "label": "Espacio interno de tarjeta", "min": 18, "max": 42, "step": 2, "unit": "px", "default": 28 },
    { "type": "range", "id": "image_size", "label": "Tamaño de imagen", "min": 48, "max": 96, "step": 4, "unit": "px", "default": 72 },
    {
      "type": "select",
      "id": "card_text_align",
      "label": "Alineación del texto",
      "default": "center",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" }
      ]
    },
    {
      "type": "select",
      "id": "card_content_position",
      "label": "Posición de imagen y estrellas",
      "default": "center",
      "options": [
        { "value": "flex-start", "label": "Izquierda" },
        { "value": "center", "label": "Centro" }
      ]
    },
    { "type": "color", "id": "background_color", "label": "Fondo de sección", "default": "#ffffff" },
    { "type": "color", "id": "card_background", "label": "Fondo de tarjetas", "default": "#f5f3ef" },
    { "type": "color", "id": "text_color", "label": "Color de texto", "default": "#18241f" },
    { "type": "color", "id": "muted_color", "label": "Color secundario", "default": "#66746d" },
    { "type": "color", "id": "accent_color", "label": "Color estrellas/acento", "default": "#155b3d" },
    { "type": "range", "id": "padding_top", "label": "Espacio superior", "min": 28, "max": 120, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Espacio inferior", "min": 28, "max": 140, "step": 4, "unit": "px", "default": 88 }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonio",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagen del cliente" },
        { "type": "text", "id": "image_alt", "label": "Texto alternativo de la imagen" },
        { "type": "text", "id": "initials", "label": "Iniciales si no hay imagen", "default": "NV" },
        { "type": "range", "id": "rating", "label": "Estrellas", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "title", "label": "Título", "default": "Compra clara y confiable" },
        { "type": "textarea", "id": "quote", "label": "Texto", "default": "Me gustó encontrar información clara, atención rápida y una compra sencilla. Volvería a comprar en Novaren." },
        { "type": "text", "id": "name", "label": "Nombre", "default": "Cliente Novaren" },
        { "type": "text", "id": "meta", "label": "Edad y ciudad", "default": "Compra verificada" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Novaren testimonios",
      "blocks": [
        { "type": "testimonial", "settings": { "initials": "CM", "title": "Más tranquilidad", "quote": "La información fue clara y el proceso de compra se sintió seguro. Me gustó poder resolver dudas antes de comprar.", "name": "Carlos M.", "meta": "Medellín" } },
        { "type": "testimonial", "settings": { "initials": "JR", "title": "Compra sencilla", "quote": "Encontré el producto rápido, el pago fue práctico y recibí orientación sobre el pedido. Buena experiencia.", "name": "Javier R.", "meta": "Bogotá" } },
        { "type": "testimonial", "settings": { "initials": "AL", "title": "Atención cercana", "quote": "Me respondieron con claridad y sin presión. Eso me dio más confianza para comprar en Novaren.", "name": "Andrés L.", "meta": "Cali" } }
      ]
    }
  ]
}
{% endschema %}
