{% comment %}
  Carrusel de Colección Destacada - Shopify Dawn
  
  Uso: 
  1. Crear una nueva sección en tu tema: sections/featured-collection-carousel.liquid
  2. Pega este código
  3. Personaliza desde el editor de temas
{% endcomment %}

{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .featured-carousel-wrapper {
    --carousel-accent: {{ section.settings.accent_color | default: '#d4af37' }};
    --carousel-text: {{ section.settings.text_color | default: '#1a1a1a' }};
    --carousel-bg: {{ section.settings.background_color | default: '#fafafa' }};
    --items-per-view: {{ section.settings.items_per_view | default: 4 }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background: var(--carousel-bg);
    overflow: hidden;
  }

  .featured-carousel-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .carousel-header {
    text-align: center;
    margin-bottom: 3rem;
    animation: fadeInUp 0.8s ease-out;
  }

  .carousel-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: {{ section.settings.title_size }}px;
    font-weight: 600;
    color: var(--carousel-text);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .carousel-description {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: {{ section.settings.description_size }}px;
    color: rgba(26, 26, 26, 0.7);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .carousel-track-wrapper {
    position: relative;
    margin: 0 -1rem;
  }

  .carousel-track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    padding: 1rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .carousel-card {
    flex: 0 0 auto;
    width: calc((100% - (var(--items-per-view) - 1) * 1.5rem) / var(--items-per-view));
    min-width: 280px;
    scroll-snap-align: center;
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    animation: slideIn 0.6s ease-out backwards;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .carousel-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
  }

  .carousel-card:nth-child(1) { animation-delay: 0.1s; }
  .carousel-card:nth-child(2) { animation-delay: 0.2s; }
  .carousel-card:nth-child(3) { animation-delay: 0.3s; }
  .carousel-card:nth-child(4) { animation-delay: 0.4s; }

  .card-image-wrapper {
    position: relative;
    padding-top: 140%;
    overflow: hidden;
    background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
  }

  .card-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .carousel-card:hover .card-image {
    transform: scale(1.08);
  }

  .card-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--carousel-accent);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    z-index: 2;
    animation: pulse 2s ease-in-out infinite;
  }

  .card-content {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--carousel-text);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .card-price {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--carousel-accent);
    margin-bottom: 1rem;
    margin-top: auto;
  }

  .card-button {
    width: 100%;
    padding: 1rem;
    background: var(--carousel-text);
    color: white;
    border: none;
    border-radius: 50px;
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: block;
    text-align: center;
  }

  .card-button:hover {
    background: var(--carousel-accent);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
  }

  .carousel-controls {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .carousel-btn {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: white;
    border: 2px solid var(--carousel-accent);
    color: var(--carousel-accent);
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
  }

  .carousel-btn:hover {
    background: var(--carousel-accent);
    color: white;
    transform: scale(1.1);
  }

  .carousel-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .view-all-button-wrapper {
    text-align: center;
    margin-top: 2.5rem;
  }

  .view-all-button {
    display: inline-block;
    padding: 1rem 3rem;
    background: transparent;
    color: var(--carousel-text);
    border: 2px solid var(--carousel-text);
    border-radius: 50px;
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .view-all-button:hover {
    background: var(--carousel-text);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateX(50px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  @media (max-width: 768px) {
    .featured-carousel-wrapper {
      --items-per-view: 2;
    }
    
    .featured-carousel-container {
      padding: 0 1rem;
    }
    
    .carousel-header {
      margin-bottom: 2rem;
    }

    .carousel-title {
      font-size: calc({{ section.settings.title_size }}px * 0.7);
    }

    .carousel-description {
      font-size: calc({{ section.settings.description_size }}px * 0.9);
    }

    .carousel-track {
      gap: 1rem;
    }

    .carousel-card {
      min-width: 250px;
    }
  }

  @media (max-width: 480px) {
    .featured-carousel-wrapper {
      --items-per-view: 1;
    }

    .carousel-card {
      min-width: 100%;
      width: calc(100% - 2rem);
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .featured-carousel-wrapper {
      --items-per-view: 3;
    }
  }
{%- endstyle -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet">

<div class="featured-carousel-wrapper">
  <div class="featured-carousel-container">
    
    {% if section.settings.title != blank or section.settings.description != blank %}
      <div class="carousel-header">
        {% if section.settings.title != blank %}
          <h2 class="carousel-title">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <p class="carousel-description">{{ section.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="carousel-track-wrapper">
      <div class="carousel-track" id="carouselTrack">
        {% if section.settings.collection != blank %}
          {% for product in section.settings.collection.products limit: section.settings.products_to_show %}
            <div class="carousel-card">
              <div class="card-image-wrapper">
                {% if product.featured_image %}
                  <img 
                    class="card-image"
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    srcset="{{ product.featured_image | image_url: width: 400 }} 400w,
                            {{ product.featured_image | image_url: width: 600 }} 600w,
                            {{ product.featured_image | image_url: width: 800 }} 800w"
                    sizes="(max-width: 768px) 85vw, 380px"
                    alt="{{ product.featured_image.alt | escape }}"
                    loading="lazy"
                  >
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'card-image' }}
                {% endif %}
                
                {% if product.compare_at_price > product.price %}
                  <div class="card-badge">¡Oferta!</div>
                {% elsif product.available == false %}
                  <div class="card-badge">Agotado</div>
                {% endif %}
              </div>

              <div class="card-content">
                <h3 class="card-title">{{ product.title }}</h3>
                <div class="card-price">
                  {% if product.compare_at_price > product.price %}
                    <span style="text-decoration: line-through; opacity: 0.5; margin-right: 0.5rem;">
                      {{ product.compare_at_price | money }}
                    </span>
                  {% endif %}
                  {{ product.price | money }}
                </div>
                <a href="{{ product.url }}" class="card-button">
                  {% if product.available %}
                    Ver Producto
                  {% else %}
                    Ver Detalles
                  {% endif %}
                </a>
              </div>
            </div>
          {% endfor %}
        {% else %}
          {% comment %} Productos de ejemplo si no hay colección seleccionada {% endcomment %}
          {% for i in (1..4) %}
            <div class="carousel-card">
              <div class="card-image-wrapper">
                {{ 'product-' | append: i | placeholder_svg_tag: 'card-image' }}
                <div class="card-badge">Nuevo</div>
              </div>
              <div class="card-content">
                <h3 class="card-title">Producto de Ejemplo {{ i }}</h3>
                <div class="card-price">$99.99</div>
                <a href="#" class="card-button">Ver Producto</a>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    {% if section.settings.show_controls %}
      <div class="carousel-controls">
        <button class="carousel-btn" id="prevBtn" aria-label="Anterior">‹</button>
        <button class="carousel-btn" id="nextBtn" aria-label="Siguiente">›</button>
      </div>
    {% endif %}

    {% if section.settings.show_view_all and section.settings.collection != blank %}
      <div class="view-all-button-wrapper">
        <a href="{{ section.settings.collection.url }}" class="view-all-button">
          {{ section.settings.view_all_text }}
        </a>
      </div>
    {% endif %}

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const track = document.getElementById('carouselTrack');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    
    if (!track || !prevBtn || !nextBtn) return;

    const cards = track.querySelectorAll('.carousel-card');
    const cardWidth = cards[0]?.offsetWidth || 0;
    const gap = 24; // 1.5rem en pixels
    const scrollAmount = cardWidth + gap;

    // Auto-scroll suave
    let autoScrollInterval;
    const startAutoScroll = () => {
      autoScrollInterval = setInterval(() => {
        if (track.scrollLeft + track.offsetWidth >= track.scrollWidth - 10) {
          track.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        }
      }, {{ section.settings.autoplay_speed | default: 5000 }});
    };

    {% if section.settings.enable_autoplay %}
      startAutoScroll();
      
      // Pausar auto-scroll al hover
      track.addEventListener('mouseenter', () => clearInterval(autoScrollInterval));
      track.addEventListener('mouseleave', startAutoScroll);
    {% endif %}

    // Controles manuales
    prevBtn.addEventListener('click', () => {
      track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });

    // Actualizar estado de botones
    const updateButtons = () => {
      prevBtn.disabled = track.scrollLeft <= 0;
      nextBtn.disabled = track.scrollLeft + track.offsetWidth >= track.scrollWidth - 10;
    };

    track.addEventListener('scroll', updateButtons);
    updateButtons();

    // Touch swipe mejorado
    let startX, scrollLeft;
    
    track.addEventListener('touchstart', (e) => {
      startX = e.touches[0].pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });

    track.addEventListener('touchmove', (e) => {
      if (!startX) return;
      const x = e.touches[0].pageX - track.offsetLeft;
      const walk = (x - startX) * 2;
      track.scrollLeft = scrollLeft - walk;
    });
  });
</script>

{% schema %}
{
  "name": "Carrusel de Colección",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Colección Destacada"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripción",
      "default": "Descubre nuestra selección especial de productos exclusivos"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Tamaño del título (px)",
      "min": 24,
      "max": 72,
      "step": 2,
      "default": 48
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Tamaño de la descripción (px)",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 18
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Productos a mostrar",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "items_per_view",
      "label": "Productos visibles en pantalla",
      "info": "Cuántos productos se muestran al mismo tiempo en pantallas grandes",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Mostrar controles de navegación",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Mostrar botón 'Ver Todos'",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Texto del botón 'Ver Todos'",
      "default": "Ver Todos los Productos"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Activar desplazamiento automático",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Velocidad de autoplay (ms)",
      "min": 2000,
      "max": 9000,
      "step": 500,
      "default": 5000
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento",
      "default": "#d4af37"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de texto",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#fafafa"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espaciado superior",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espaciado inferior",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Carrusel de Colección"
    }
  ]
}
{% endschema %}