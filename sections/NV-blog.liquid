{% liquid
  assign selected_blog = blogs[section.settings.blog]
%}

<section class="nvbloghome section-{{ section.id }}">
  <div class="nvbloghome-shell">
    <header class="nvbloghome-head">
      <p>{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <div>{{ section.settings.text }}</div>
    </header>

    {% if selected_blog != blank and selected_blog.articles_count > 0 %}
      <div class="nvbloghome-grid">
        {% for article in selected_blog.articles limit: section.settings.limit %}
          <article class="nvbloghome-card">
            <a class="nvbloghome-card__media" href="{{ article.url }}" aria-label="{{ article.title | escape }}">
              {% if article.image != blank %}
                {{
                  article.image
                  | image_url: width: 900
                  | image_tag:
                    widths: '320, 480, 640, 900',
                    sizes: '(min-width: 990px) 30vw, 90vw',
                    loading: 'lazy',
                    class: 'nvbloghome-card__image',
                    alt: article.image.alt | default: article.title
                }}
              {% endif %}
            </a>
            <div class="nvbloghome-card__body">
              <p>{{ section.settings.article_kicker }}</p>
              <h3><a href="{{ article.url }}">{{ article.title }}</a></h3>
              <a href="{{ article.url }}">{{ section.settings.article_link_label }}</a>
            </div>
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  .section-{{ section.id }} {
    --ink: #10231c;
    --muted: #647067;
    --green: #155b3d;
    --line: rgba(16,35,28,.12);
    background: {{ section.settings.background }};
    color: var(--ink);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow-x: hidden;
  }

  .section-{{ section.id }} .nvbloghome-shell {
    width: calc(100% - 32px);
    max-width: 1180px;
    margin-inline: auto;
  }

  .section-{{ section.id }} .nvbloghome-head {
    max-width: 740px;
    margin-bottom: 34px;
  }

  .section-{{ section.id }} .nvbloghome-head p,
  .section-{{ section.id }} .nvbloghome-card__body p {
    color: var(--green);
    font-size: 12px;
    font-weight: 850;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .section-{{ section.id }} .nvbloghome-head p {
    margin: 0 0 12px;
  }

  .section-{{ section.id }} .nvbloghome-head h2 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.02;
    letter-spacing: 0;
  }

  .section-{{ section.id }} .nvbloghome-head div {
    margin-top: 16px;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.65;
  }

  .section-{{ section.id }} .nvbloghome-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: 18px;
  }

  .section-{{ section.id }} .nvbloghome-card {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255,255,255,.82);
    box-shadow: 0 20px 60px rgba(16,35,28,.08);
    transition: transform .24s ease, box-shadow .24s ease;
  }

  .section-{{ section.id }} .nvbloghome-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 28px 76px rgba(16,35,28,.14);
  }

  .section-{{ section.id }} .nvbloghome-card__media {
    display: block;
    aspect-ratio: 1.35 / 1;
    overflow: hidden;
    background: #fff;
  }

  .section-{{ section.id }} .nvbloghome-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .section-{{ section.id }} .nvbloghome-card__body {
    padding: 20px;
  }

  .section-{{ section.id }} .nvbloghome-card__body p {
    margin: 0 0 10px;
  }

  .section-{{ section.id }} .nvbloghome-card h3 {
    margin: 0 0 18px;
    color: var(--ink);
    font-size: 21px;
    line-height: 1.18;
  }

  .section-{{ section.id }} .nvbloghome-card a {
    color: inherit;
    text-decoration: none;
  }

  .section-{{ section.id }} .nvbloghome-card__body > a {
    color: var(--green);
    font-weight: 900;
  }

  @media (max-width: 989px) {
    .section-{{ section.id }} .nvbloghome-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .section-{{ section.id }} .nvbloghome-shell {
      width: calc(100% - 24px);
    }

    .section-{{ section.id }} .nvbloghome-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>

