{% style %}

.cinematic-v4{

position:relative;
padding:80px 20px;

}

.cinematic-v4-inner{

max-width:{{ section.settings.banner_width }}px;
margin:auto;

border-radius:{{ section.settings.banner_radius }}px;
overflow:hidden;

position:relative;

box-shadow:
0 40px 100px rgba(0,0,0,.2),
0 20px 40px rgba(0,0,0,.12);

}

/* MEDIA */

.cinematic-v4-media{

position:relative;
width:100%;
height:{{ section.settings.banner_height }}px;

overflow:hidden;

}

.cinematic-v4-media img{

width:100%;
height:100%;

object-fit:cover;
object-position:center;

transform:scale(1.05);

transition:transform 8s cubic-bezier(.19,1,.22,1);

}

.cinematic-v4.reveal img{

transform:scale(1.12);

}

/* overlay cinematic */

.cinematic-v4-overlay{

position:absolute;
inset:0;

background:linear-gradient(
110deg,
rgba(0,0,0,.75) 0%,
rgba(0,0,0,.4) 45%,
rgba(0,0,0,0) 80%
);

}

/* content */

.cinematic-v4-content{

position:absolute;

top:50%;
left:70px;

transform:translateY(-50%);

max-width:520px;

color:white;

opacity:0;
transform:translateY(60px);

transition:all 1.2s cubic-bezier(.19,1,.22,1);

}

.cinematic-v4.reveal .cinematic-v4-content{

opacity:1;
transform:translateY(-50%);

}

.cinematic-v4-title{

font-size:64px;
line-height:1.05;

font-weight:700;

letter-spacing:-0.03em;

margin-bottom:18px;

}

.cinematic-v4-sub{

font-size:22px;

opacity:.9;

margin-bottom:30px;

}

.cinematic-v4-btn{

display:inline-block;

background:white;
color:black;

padding:16px 40px;

border-radius:999px;

font-weight:600;

text-decoration:none;

transition:all .3s ease;

}

.cinematic-v4-btn:hover{

transform:translateY(-4px);

box-shadow:0 20px 50px rgba(0,0,0,.35);

}

/* mobile */

@media(max-width:768px){

.cinematic-v4-media{

height:420px;

}

.cinematic-v4-content{

left:30px;
right:30px;

}

.cinematic-v4-title{

font-size:38px;

}

.cinematic-v4-sub{

font-size:16px;

}

}

{% endstyle %}



{%- liquid

assign widths = '375, 550, 750, 1100, 1500, 2000, 3000'
assign sizes = '(min-width: 1200px) 1400px, 100vw'

assign fetch_priority = 'auto'

if section.index == 1
assign fetch_priority = 'high'
endif

-%}



<section class="cinematic-v4" id="cinematic-{{ section.id }}">

<div class="cinematic-v4-inner">

<div class="cinematic-v4-media">

{% if section.settings.image != blank %}

{{
section.settings.image
| image_url: width: 3000
| image_tag:
width: section.settings.image.width,
height: section.settings.image.height,
sizes: sizes,
widths: widths,
loading: 'lazy',
fetchpriority: fetch_priority
}}

{% else %}

{{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}

{% endif %}

<div class="cinematic-v4-overlay"></div>

</div>


<div class="cinematic-v4-content">

<h2 class="cinematic-v4-title">

{{ section.settings.heading }}

</h2>

<p class="cinematic-v4-sub">

{{ section.settings.text }}

</p>

{% if section.settings.button_label != blank %}

<a class="cinematic-v4-btn" href="{{ section.settings.button_link }}">

{{ section.settings.button_label }}

</a>

{% endif %}

</div>

</div>

</section>



<script>

document.addEventListener("DOMContentLoaded", function(){

const hero = document.getElementById("cinematic-{{ section.id }}");

if(!hero) return;

const observer = new IntersectionObserver((entries)=>{

entries.forEach(entry=>{

if(entry.isIntersecting){

hero.classList.add("reveal");

}

});

},{threshold:.35});

observer.observe(hero);

});


document.addEventListener("shopify:section:load", function(){

const hero = document.getElementById("cinematic-{{ section.id }}");

if(hero){

hero.classList.add("reveal");

}

});

</script>



{% schema %}
{
"name": "Cinematic Hero V4",
"tag": "section",
"class": "section",
"settings":[

{
"type":"image_picker",
"id":"image",
"label":"Imagen Hero"
},

{
"type":"text",
"id":"heading",
"default":"Nueva colección",
"label":"Título"
},

{
"type":"text",
"id":"text",
"default":"Descubre lo último",
"label":"Texto"
},

{
"type":"text",
"id":"button_label",
"default":"Comprar ahora",
"label":"Botón"
},

{
"type":"url",
"id":"button_link",
"label":"Link botón"
},

{
"type":"range",
"id":"banner_width",
"min":1000,
"max":1800,
"step":50,
"default":1400,
"label":"Ancho banner"
},

{
"type":"range",
"id":"banner_height",
"min":400,
"max":900,
"step":50,
"default":550,
"label":"Altura banner"
},

{
"type":"range",
"id":"banner_radius",
"min":0,
"max":40,
"step":2,
"default":28,
"label":"Bordes redondeados"
}

],

"presets":[
{
"name":"Cinematic Hero V4"
}
]

}
{% endschema %}