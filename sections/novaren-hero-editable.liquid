<section class="nve-hero section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="nve-hero__media" aria-hidden="true">
    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 2200
        | image_tag:
          widths: '720, 960, 1200, 1600, 2200',
          sizes: '(min-width: 990px) 62vw, 100vw',
          loading: 'eager',
          fetchpriority: 'high',
          class: 'nve-hero__image',
          alt: section.settings.image_alt
      }}
    {% endif %}
  </div>

  <div class="nve-shell nve-hero__grid">
    <div class="nve-hero__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="nve-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h1>{{ section.settings.heading }}</h1>
      {% if section.settings.text != blank %}
        <p class="nve-hero__text">{{ section.settings.text }}</p>
      {% endif %}
      <div class="nve-actions">
        {% if section.settings.primary_label != blank %}
          <a class="nve-button nve-button--primary" href="{{ section.settings.primary_link }}">
            {{ section.settings.primary_label }}
          </a>
        {% endif %}
        {% if section.settings.secondary_label != blank %}
          <a class="nve-button nve-button--ghost" href="{{ section.settings.secondary_link }}">
            {{ section.settings.secondary_label }}
          </a>
        {% endif %}
      </div>
    </div>

    {% if section.settings.panel_heading != blank or section.settings.panel_text != blank %}
      <aside class="nve-hero__panel">
        {% if section.settings.panel_eyebrow != blank %}
          <span>{{ section.settings.panel_eyebrow }}</span>
        {% endif %}
        {% if section.settings.panel_heading != blank %}
          <strong>{{ section.settings.panel_heading }}</strong>
        {% endif %}
        {% if section.settings.panel_text != blank %}
          <p>{{ section.settings.panel_text }}</p>
        {% endif %}
      </aside>
    {% endif %}
  </div>
</section>

<style>
  .section-{{ section.id }} {
    --ink: {{ section.settings.ink_color }};
    --muted: {{ section.settings.muted_color }};
    --green: {{ section.settings.accent_color }};
    --cream: {{ section.settings.background_color }};
    --line: rgba(16, 35, 28, .12);
    position: relative;
    min-height: clamp(620px, 88vh, 840px);
    display: grid;
    align-items: center;
    isolation: isolate;
    overflow: hidden;
    background: var(--cream);
    color: var(--ink);
  }

  .section-{{ section.id }} * { box-sizing: border-box; }

  .section-{{ section.id }} .nve-shell {
    width: calc(100% - 32px);
    max-width: 1180px;
    margin-inline: auto;
  }

  .section-{{ section.id }} .nve-hero__media {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .section-{{ section.id }} .nve-hero__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(251,250,245,.97) 0%, rgba(251,250,245,.86) 36%, rgba(251,250,245,.28) 68%, rgba(251,250,245,.08) 100%);
  }

  .section-{{ section.id }} .nve-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_position }};
    display: block;
  }

  .section-{{ section.id }} .nve-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 620px) minmax(280px, 360px);
    gap: clamp(28px, 5vw, 86px);
    align-items: end;
    padding: clamp(64px, 8vw, 96px) 0 clamp(54px, 7vw, 78px);
  }

  .section-{{ section.id }} .nve-hero__copy,
  .section-{{ section.id }} .nve-hero__panel,
  .section-{{ section.id }} .nve-actions {
    min-width: 0;
    max-width: 100%;
  }

  .section-{{ section.id }} .nve-eyebrow,
  .section-{{ section.id }} .nve-hero__panel span {
    margin: 0 0 14px;
    color: var(--green);
    font-size: {{ section.settings.eyebrow_font_size }}px;
    font-weight: 850;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .section-{{ section.id }} h1 {
    max-width: {{ section.settings.heading_max_width }}ch;
    margin: 0;
    color: var(--ink);
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    line-height: {{ section.settings.heading_line_height }}%;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .section-{{ section.id }} .nve-hero__text {
    max-width: 590px;
    margin: 24px 0 0;
    color: var(--muted);
    font-size: {{ section.settings.text_font_size_desktop }}px;
    line-height: {{ section.settings.text_line_height }}%;
  }

  .section-{{ section.id }} .nve-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  .section-{{ section.id }} .nve-button {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 13px 20px;
    border-radius: {{ section.settings.button_radius }}px;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 850;
    text-decoration: none;
    transition: transform .22s ease, box-shadow .22s ease, background-color .22s ease;
  }

  .section-{{ section.id }} .nve-button:hover {
    transform: translateY(-2px);
  }

  .section-{{ section.id }} .nve-button--primary {
    color: #fff;
    background: var(--green);
    box-shadow: 0 16px 34px rgba(21, 91, 61, .22);
  }

  .section-{{ section.id }} .nve-button--ghost {
    color: var(--ink);
    background: rgba(255,255,255,.76);
    border: 1px solid var(--line);
  }

  .section-{{ section.id }} .nve-hero__panel {
    min-width: 0;
    max-width: 100%;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255,255,255,.75);
    padding: 24px;
    box-shadow: 0 24px 70px rgba(16,35,28,.12);
    backdrop-filter: blur(14px);
  }

  .section-{{ section.id }} .nve-hero__panel strong {
    display: block;
    margin-top: 12px;
    color: var(--ink);
    font-size: {{ section.settings.panel_heading_font_size }}px;
    line-height: {{ section.settings.panel_heading_line_height }}%;
  }

  .section-{{ section.id }} .nve-hero__panel p {
    margin: 14px 0 0;
    color: var(--muted);
    font-size: {{ section.settings.panel_text_font_size }}px;
    line-height: {{ section.settings.panel_text_line_height }}%;
  }

  @media (max-width: 989px) {
    .section-{{ section.id }} {
      min-height: auto;
    }

    .section-{{ section.id }} .nve-hero__media::after {
      background: linear-gradient(180deg, rgba(251,250,245,.98) 0%, rgba(251,250,245,.88) 55%, rgba(251,250,245,.35) 100%);
    }

    .section-{{ section.id }} .nve-hero__grid {
      grid-template-columns: minmax(0, 1fr);
      width: calc(100vw - 24px);
      max-width: calc(100vw - 24px);
      padding: 72px 0 54px;
      overflow: hidden;
    }

    .section-{{ section.id }} h1 {
      max-width: 100%;
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }

    .section-{{ section.id }} .nve-hero__copy,
    .section-{{ section.id }} .nve-hero__panel,
    .section-{{ section.id }} .nve-actions {
      width: 100%;
      max-width: 330px;
    }

    .section-{{ section.id }} .nve-hero__text {
      max-width: 100%;
      font-size: {{ section.settings.text_font_size_mobile }}px;
    }

    .section-{{ section.id }} .nve-hero__panel strong {
      font-size: {{ section.settings.panel_heading_font_size_mobile }}px;
    }
  }

  @media (max-width: 640px) {
    .section-{{ section.id }} .nve-shell {
      width: calc(100% - 24px);
    }

    .section-{{ section.id }} .nve-actions {
      flex-direction: column;
    }

    .section-{{ section.id }} .nve-button {
      width: 100%;
    }
  }
</style>

