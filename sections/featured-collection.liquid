{{ 'component-price.css' | asset_url | stylesheet_tag }}

<style>
#coleccion-premium-{{ section.id }}{
  background: {{ section.settings.background }};
  padding:
    {{ section.settings.padding_top }}px
    {{ section.settings.padding_side }}px
    {{ section.settings.padding_bottom }}px;
}

/* CONTENEDOR */

#coleccion-premium-{{ section.id }} .contenedor{
  max-width: {{ section.settings.container_width }}px;
  margin:0 auto;
}

/* TITULO */

#coleccion-premium-{{ section.id }} .titulo{
  text-align:center;
  font-size:{{ section.settings.title_size }}px;
  line-height:1.1;
  font-weight:800;
  color:{{ section.settings.title_color }};
  margin:0 0 42px;
  letter-spacing:-0.04em;
}

/* GRID */

#coleccion-premium-{{ section.id }} .grid-productos{
  display:grid;
  grid-template-columns:repeat({{ section.settings.columns_desktop }},1fr);
  gap:{{ section.settings.grid_gap }}px;
}

/* TARJETA */

#coleccion-premium-{{ section.id }} .producto-card{
  display:flex;
  flex-direction:column;
  background:#fff;
  border-radius:{{ section.settings.card_radius }}px;
  overflow:hidden;
  box-shadow:0 14px 40px rgba(15,23,42,.08);
  transition:all .3s ease;
}

#coleccion-premium-{{ section.id }} .producto-card:hover{
  transform:translateY(-6px);
  box-shadow:0 24px 60px rgba(15,23,42,.13);
}

/* IMAGEN */

#coleccion-premium-{{ section.id }} .producto-imagen{
  display:block;
  background:#fff;
  overflow:hidden;
}

#coleccion-premium-{{ section.id }} .producto-imagen img{
  width:100%;
  height:auto;
  display:block;
  object-fit:cover;
}

/* INFO */

#coleccion-premium-{{ section.id }} .producto-info{
  display:flex;
  flex:1;
  flex-direction:column;
  padding:{{ section.settings.card_padding }}px;
}

/* NOMBRE */

#coleccion-premium-{{ section.id }} .producto-titulo{
  margin:0 0 16px;
  line-height:1.15;
  font-weight:800;
}

#coleccion-premium-{{ section.id }} .producto-titulo a{
  text-decoration:none;
  color:{{ section.settings.product_title_color }};
  font-size:{{ section.settings.product_title_size }}px;
  letter-spacing:-0.03em;
}

/* PRECIO */

#coleccion-premium-{{ section.id }} .precio-comparado{
  display:block;
  font-size:{{ section.settings.compare_price_size }}px;
  color:#9ca3af;
  text-decoration:line-through;
  margin-bottom:8px;
  font-weight:700;
}

#coleccion-premium-{{ section.id }} .precio{
  display:block;
  font-size:{{ section.settings.price_size }}px;
  line-height:1;
  font-weight:900;
  color:{{ section.settings.price_color }};
  letter-spacing:-0.05em;
  margin-bottom:20px;
}

/* BOTON */

#coleccion-premium-{{ section.id }} .boton{
  display:flex;
  width:100%;
  justify-content:center;
  align-items:center;
  text-decoration:none;
  margin-top:auto;
  min-height:56px;
  border-radius:999px;
  background:{{ section.settings.button_bg }};
  color:{{ section.settings.button_text_color }};
  font-size:{{ section.settings.button_size }}px;
  font-weight:800;
  transition:all .3s ease;
}

#coleccion-premium-{{ section.id }} .boton:hover{
  background:{{ section.settings.button_hover }};
  transform:translateY(-2px);
}

/* MOBILE */

@media screen and (max-width:749px){

  #coleccion-premium-{{ section.id }}{
    padding-left:{{ section.settings.mobile_side_padding }}px;
    padding-right:{{ section.settings.mobile_side_padding }}px;
  }

  #coleccion-premium-{{ section.id }} .grid-productos{
    grid-template-columns:repeat({{ section.settings.columns_mobile }},1fr);
    gap:{{ section.settings.mobile_gap }}px;
  }

  #coleccion-premium-{{ section.id }} .titulo{
    font-size:{{ section.settings.mobile_title_size }}px;
    margin-bottom:28px;
  }

  #coleccion-premium-{{ section.id }} .producto-card{
    border-radius:{{ section.settings.mobile_card_radius }}px;
  }

  #coleccion-premium-{{ section.id }} .producto-info{
    padding:{{ section.settings.mobile_card_padding }}px;
  }

  #coleccion-premium-{{ section.id }} .producto-titulo a{
    font-size:{{ section.settings.mobile_product_title_size }}px;
  }

  #coleccion-premium-{{ section.id }} .precio{
    font-size:{{ section.settings.mobile_price_size }}px;
  }

  #coleccion-premium-{{ section.id }} .boton{
    font-size:{{ section.settings.mobile_button_size }}px;
  }
}
</style>

<section id="coleccion-premium-{{ section.id }}">
  <div class="contenedor">

    {% if section.settings.title != blank %}
      <h2 class="titulo">
        {{ section.settings.title }}
      </h2>
    {% endif %}

    <div class="grid-productos">

      {% for product in section.settings.collection.products limit: section.settings.products_to_show %}

        <div class="producto-card">

          <a href="{{ product.url }}" class="producto-imagen">

            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 1600 }}"
                alt="{{ product.title | escape }}"
                loading="lazy"
              >
            {% endif %}

          </a>

          <div class="producto-info">

            <h3 class="producto-titulo">
              <a href="{{ product.url }}">
                {{ product.title }}
              </a>
            </h3>

            {% if product.compare_at_price > product.price %}
              <span class="precio-comparado">
                {{ product.compare_at_price | money }}
              </span>
            {% endif %}

            <span class="precio">
              {{ product.price | money }}
            </span>

            {% if section.settings.show_button %}
              <a href="{{ product.url }}" class="boton">
                {{ section.settings.button_text }}
              </a>
            {% endif %}

          </div>

        </div>

      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name":"Colección premium",
  "settings":[

    {
      "type":"collection",
      "id":"collection",
      "label":"Colección"
    },

    {
      "type":"text",
      "id":"title",
      "label":"Título",
      "default":"Productos destacados"
    },

    {
      "type":"color",
      "id":"background",
      "label":"Fondo",
      "default":"#f8fafc"
    },

    {
      "type":"range",
      "id":"container_width",
      "min":900,
      "max":1800,
      "step":20,
      "unit":"px",
      "label":"Ancho contenedor",
      "default":1400
    },

    {
      "type":"range",
      "id":"columns_desktop",
      "min":1,
      "max":8,
      "step":1,
      "label":"Columnas desktop",
      "default":4
    },

    {
      "type":"select",
      "id":"columns_mobile",
      "label":"Columnas móvil",
      "default":"1",
      "options":[
        {
          "value":"1",
          "label":"1 columna"
        },
        {
          "value":"2",
          "label":"2 columnas"
        }
      ]
    },

    {
      "type":"range",
      "id":"products_to_show",
      "min":1,
      "max":20,
      "step":1,
      "label":"Productos",
      "default":4
    },

    {
      "type":"range",
      "id":"grid_gap",
      "min":10,
      "max":60,
      "step":2,
      "unit":"px",
      "label":"Espacio grid desktop",
      "default":30
    },

    {
      "type":"range",
      "id":"mobile_gap",
      "min":6,
      "max":40,
      "step":2,
      "unit":"px",
      "label":"Espacio grid móvil",
      "default":20
    },

    {
      "type":"range",
      "id":"card_radius",
      "min":0,
      "max":40,
      "step":2,
      "unit":"px",
      "label":"Radio tarjeta desktop",
      "default":28
    },

    {
      "type":"range",
      "id":"mobile_card_radius",
      "min":0,
      "max":40,
      "step":2,
      "unit":"px",
      "label":"Radio tarjeta móvil",
      "default":24
    },

    {
      "type":"range",
      "id":"card_padding",
      "min":10,
      "max":50,
      "step":2,
      "unit":"px",
      "label":"Padding desktop",
      "default":24
    },

    {
      "type":"range",
      "id":"mobile_card_padding",
      "min":10,
      "max":40,
      "step":2,
      "unit":"px",
      "label":"Padding móvil",
      "default":20
    },

    {
      "type":"range",
      "id":"title_size",
      "min":20,
      "max":80,
      "step":2,
      "unit":"px",
      "label":"Título desktop",
      "default":46
    },

    {
      "type":"range",
      "id":"mobile_title_size",
      "min":18,
      "max":60,
      "step":2,
      "unit":"px",
      "label":"Título móvil",
      "default":32
    },

    {
      "type":"range",
      "id":"product_title_size",
      "min":14,
      "max":42,
      "step":1,
      "unit":"px",
      "label":"Nombre producto desktop",
      "default":24
    },

    {
      "type":"range",
      "id":"mobile_product_title_size",
      "min":12,
      "max":36,
      "step":1,
      "unit":"px",
      "label":"Nombre producto móvil",
      "default":20
    },

    {
      "type":"range",
      "id":"price_size",
      "min":18,
      "max":60,
      "step":2,
      "unit":"px",
      "label":"Precio desktop",
      "default":36
    },

    {
      "type":"range",
      "id":"mobile_price_size",
      "min":16,
      "max":50,
      "step":2,
      "unit":"px",
      "label":"Precio móvil",
      "default":30
    },

    {
      "type":"range",
      "id":"compare_price_size",
      "min":10,
      "max":30,
      "step":1,
      "unit":"px",
      "label":"Precio tachado",
      "default":18
    },

    {
      "type":"color",
      "id":"title_color",
      "label":"Color título",
      "default":"#10233f"
    },

    {
      "type":"color",
      "id":"product_title_color",
      "label":"Color nombre producto",
      "default":"#10233f"
    },

    {
      "type":"color",
      "id":"price_color",
      "label":"Color precio",
      "default":"#0f766e"
    },

    {
      "type":"checkbox",
      "id":"show_button",
      "label":"Mostrar botón",
      "default":true
    },

    {
      "type":"text",
      "id":"button_text",
      "label":"Texto botón",
      "default":"Ver producto"
    },

    {
      "type":"color",
      "id":"button_bg",
      "label":"Botón fondo",
      "default":"#10233f"
    },

    {
      "type":"color",
      "id":"button_hover",
      "label":"Botón hover",
      "default":"#10b981"
    },

    {
      "type":"color",
      "id":"button_text_color",
      "label":"Texto botón",
      "default":"#ffffff"
    },

    {
      "type":"range",
      "id":"button_size",
      "min":12,
      "max":28,
      "step":1,
      "unit":"px",
      "label":"Botón desktop",
      "default":16
    },

    {
      "type":"range",
      "id":"mobile_button_size",
      "min":10,
      "max":24,
      "step":1,
      "unit":"px",
      "label":"Botón móvil",
      "default":15
    },

    {
      "type":"range",
      "id":"padding_top",
      "min":0,
      "max":120,
      "step":4,
      "unit":"px",
      "label":"Padding top",
      "default":60
    },

    {
      "type":"range",
      "id":"padding_bottom",
      "min":0,
      "max":120,
      "step":4,
      "unit":"px",
      "label":"Padding bottom",
      "default":60
    },

    {
      "type":"range",
      "id":"padding_side",
      "min":0,
      "max":80,
      "step":2,
      "unit":"px",
      "label":"Padding lateral desktop",
      "default":20
    },

    {
      "type":"range",
      "id":"mobile_side_padding",
      "min":0,
      "max":40,
      "step":2,
      "unit":"px",
      "label":"Padding lateral móvil",
      "default":10
    }

  ],

  "presets":[
    {
      "name":"Colección premium"
    }
  ]
}
{% endschema %}
