<section class="nvpl section-{{ section.id }}">
  <div class="nvpl-shell">
    <header class="nvpl-head">
      {% if section.settings.eyebrow != blank %}<p>{{ section.settings.eyebrow }}</p>{% endif %}
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.text != blank %}<div>{{ section.settings.text }}</div>{% endif %}
    </header>

    <div class="nvpl-feature">
      <div class="nvpl-feature__copy">
        <span>{{ section.settings.feature_badge }}</span>
        <h3>{{ section.settings.feature_heading }}</h3>
        <p>{{ section.settings.feature_text }}</p>
      </div>
      {% if section.settings.feature_image != blank %}
        {{
          section.settings.feature_image
          | image_url: width: 1200
          | image_tag:
            widths: '420, 640, 900, 1200',
            sizes: '(min-width: 900px) 44vw, 100vw',
            loading: 'lazy',
            class: 'nvpl-feature__image',
            alt: section.settings.feature_image_alt
        }}
      {% elsif product.featured_media != blank %}
        {{
          product.featured_media
          | image_url: width: 1200
          | image_tag:
            widths: '420, 640, 900, 1200',
            sizes: '(min-width: 900px) 44vw, 100vw',
            loading: 'lazy',
            class: 'nvpl-feature__image',
            alt: product.featured_media.alt | default: product.title
        }}
      {% endif %}
    </div>

    <div class="nvpl-cards">
      {% for block in section.blocks %}
        {% if block.type == 'benefit' %}
          <article class="nvpl-card" {{ block.shopify_attributes }}>
            <span>{{ block.settings.kicker }}</span>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>

    <div class="nvpl-steps">
      <div>
        <p>{{ section.settings.steps_eyebrow }}</p>
        <h3>{{ section.settings.steps_heading }}</h3>
      </div>
      <ol>
        {% for block in section.blocks %}
          {% if block.type == 'step' %}
            <li {{ block.shopify_attributes }}>
              <strong>{{ block.settings.title }}</strong>
              <span>{{ block.settings.text }}</span>
            </li>
          {% endif %}
        {% endfor %}
      </ol>
    </div>

    <div class="nvpl-faq">
      <header>
        <p>{{ section.settings.faq_eyebrow }}</p>
        <h3>{{ section.settings.faq_heading }}</h3>
      </header>
      {% for block in section.blocks %}
        {% if block.type == 'faq' %}
          <details {{ block.shopify_attributes }}>
            <summary>{{ block.settings.question }}</summary>
            <div>{{ block.settings.answer }}</div>
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .section-{{ section.id }} {
    --ink: #10231c;
    --muted: #66746d;
    --green: {{ section.settings.accent_color }};
    --line: rgba(16,35,28,.12);
    background: {{ section.settings.background }};
    color: var(--ink);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  .section-{{ section.id }} .nvpl-shell {
    width: calc(100% - 32px);
    max-width: 1060px;
    margin-inline: auto;
  }

  .section-{{ section.id }} .nvpl-head {
    max-width: 760px;
    margin: 0 auto 28px;
    text-align: center;
  }

  .section-{{ section.id }} .nvpl-head p,
  .section-{{ section.id }} .nvpl-steps p,
  .section-{{ section.id }} .nvpl-faq header p {
    margin: 0 0 10px;
    color: var(--green);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .section-{{ section.id }} .nvpl-head h2 {
    margin: 0;
    color: var(--ink);
    font-size: {{ section.settings.heading_font_size }}px;
    line-height: 1.05;
  }

  .section-{{ section.id }} .nvpl-head div {
    margin-top: 14px;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.65;
  }

  .section-{{ section.id }} .nvpl-feature {
    display: grid;
    grid-template-columns: minmax(0, .92fr) minmax(0, 1.08fr);
    align-items: center;
    gap: 22px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background:
      radial-gradient(circle at 0% 0%, rgba(21,91,61,.12), transparent 32%),
      #ffffff;
    padding: clamp(20px, 4vw, 34px);
    box-shadow: 0 20px 64px rgba(16,35,28,.09);
  }

  .section-{{ section.id }} .nvpl-feature__copy span {
    display: inline-flex;
    border-radius: 999px;
    background: color-mix(in srgb, var(--green) 12%, #ffffff);
    color: var(--green);
    padding: 7px 10px;
    font-size: 12px;
    font-weight: 900;
  }

  .section-{{ section.id }} .nvpl-feature__copy h3 {
    margin: 16px 0 0;
    color: var(--ink);
    font-size: {{ section.settings.feature_heading_size }}px;
    line-height: 1.05;
  }

  .section-{{ section.id }} .nvpl-feature__copy p {
    margin: 14px 0 0;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.65;
  }

  .section-{{ section.id }} .nvpl-feature__image {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    border-radius: 8px;
    background: #fff;
  }

  .section-{{ section.id }} .nvpl-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 18px;
  }

  .section-{{ section.id }} .nvpl-card,
  .section-{{ section.id }} .nvpl-steps,
  .section-{{ section.id }} .nvpl-faq {
    border: 1px solid var(--line);
    border-radius: 10px;
    background: rgba(255,255,255,.9);
    box-shadow: 0 16px 48px rgba(16,35,28,.07);
  }

  .section-{{ section.id }} .nvpl-card {
    padding: 20px;
  }

  .section-{{ section.id }} .nvpl-card span {
    color: var(--green);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .1em;
    text-transform: uppercase;
  }

  .section-{{ section.id }} .nvpl-card h3 {
    margin: 12px 0 0;
    color: var(--ink);
    font-size: 19px;
    line-height: 1.2;
  }

  .section-{{ section.id }} .nvpl-card p {
    margin: 10px 0 0;
    color: var(--muted);
    line-height: 1.58;
  }

  .section-{{ section.id }} .nvpl-steps {
    display: grid;
    grid-template-columns: minmax(0, .72fr) minmax(0, 1.28fr);
    gap: 20px;
    margin-top: 18px;
    padding: clamp(22px, 4vw, 34px);
  }

  .section-{{ section.id }} .nvpl-steps h3,
  .section-{{ section.id }} .nvpl-faq h3 {
    margin: 0;
    color: var(--ink);
    font-size: 28px;
    line-height: 1.08;
  }

  .section-{{ section.id }} .nvpl-steps ol {
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: nvpl-step;
    display: grid;
    gap: 12px;
  }

  .section-{{ section.id }} .nvpl-steps li {
    counter-increment: nvpl-step;
    position: relative;
    padding-left: 48px;
    min-height: 38px;
  }

  .section-{{ section.id }} .nvpl-steps li::before {
    content: counter(nvpl-step);
    position: absolute;
    left: 0;
    top: 0;
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: var(--green);
    color: #fff;
    font-weight: 900;
  }

  .section-{{ section.id }} .nvpl-steps strong,
  .section-{{ section.id }} .nvpl-steps span {
    display: block;
  }

  .section-{{ section.id }} .nvpl-steps strong {
    color: var(--ink);
    font-size: 16px;
  }

  .section-{{ section.id }} .nvpl-steps span {
    margin-top: 4px;
    color: var(--muted);
    line-height: 1.5;
  }

  .section-{{ section.id }} .nvpl-faq {
    margin-top: 18px;
    padding: clamp(22px, 4vw, 34px);
  }

  .section-{{ section.id }} .nvpl-faq details {
    border-top: 1px solid var(--line);
    padding: 16px 0;
  }

  .section-{{ section.id }} .nvpl-faq details:first-of-type {
    margin-top: 18px;
  }

  .section-{{ section.id }} .nvpl-faq summary {
    cursor: pointer;
    color: var(--ink);
    font-weight: 900;
  }

  .section-{{ section.id }} .nvpl-faq details div {
    margin-top: 10px;
    color: var(--muted);
    line-height: 1.62;
  }

  @media (max-width: 820px) {
    .section-{{ section.id }} .nvpl-shell {
      width: calc(100% - 24px);
    }

    .section-{{ section.id }} .nvpl-head {
      text-align: left;
    }

    .section-{{ section.id }} .nvpl-head h2 {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }

    .section-{{ section.id }} .nvpl-feature,
    .section-{{ section.id }} .nvpl-cards,
    .section-{{ section.id }} .nvpl-steps {
      grid-template-columns: minmax(0, 1fr);
    }

    .section-{{ section.id }} .nvpl-feature {
      padding: 18px;
    }

    .section-{{ section.id }} .nvpl-feature__copy h3 {
      font-size: {{ section.settings.feature_heading_size_mobile }}px;
    }
  }
</style>

{% schema %}
{
  "name": "NV producto landing móvil",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Etiqueta", "default": "Rutina Novaren" },
